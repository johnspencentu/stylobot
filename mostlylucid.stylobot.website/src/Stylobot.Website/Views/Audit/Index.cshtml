@model Stylobot.Website.Portal.AuditIndexViewModel
@{
    ViewData["Title"] = $"Audit log - {Model.Org.Name}";

    string ActionBadge(string action) => action switch
    {
        "issue" or "issue-trial" => "badge-success",
        "revoke" => "badge-error",
        "download" => "badge-info",
        "member-invite" or "member-role-change" => "badge-warning",
        "member-remove" => "badge-error",
        "org-created" => "badge-primary",
        _ => "badge-ghost"
    };
}

<section class="min-h-[70vh] px-6 py-16">
  <div class="max-w-5xl mx-auto">
    <a class="btn btn-ghost btn-sm mb-4" href="/portal/org/@Model.Org.Slug">← @Model.Org.Name</a>
    <h1 class="text-3xl font-semibold">Audit log</h1>
    <p class="text-base-content/70 mt-2">
      Append-only record of every licensing and team action. Exportable for SOC 2 evidence
      (CSV export coming in 1c+). Total events: <strong>@Model.TotalCount</strong>.
    </p>

    @if (!Model.Audits.Any())
    {
      <div class="card bg-base-200 p-6 mt-8 text-base-content/70">
        No audit entries yet. Events appear here as soon as someone issues, downloads, or
        revokes a license or changes team membership.
      </div>
    }
    else
    {
      <div class="overflow-x-auto mt-8">
        <table class="table text-sm">
          <thead>
            <tr><th>When (UTC)</th><th>Action</th><th>Actor</th><th>Detail</th></tr>
          </thead>
          <tbody>
            @foreach (var a in Model.Audits)
            {
              <tr>
                <td class="font-mono text-xs">@a.At.ToString("yyyy-MM-dd HH:mm:ss")</td>
                <td><span class="badge @ActionBadge(a.Action)">@a.Action</span></td>
                <td>
                  @(a.ActorEmail ?? a.ActorKeycloakSub)
                  @if (a.LicenseId is not null)
                  {
                    <div class="text-xs text-base-content/50 font-mono">license: @a.LicenseId.Value.ToString()[..8]…</div>
                  }
                </td>
                <td>@(a.Reason ?? "-")</td>
              </tr>
            }
          </tbody>
        </table>
      </div>

      @if (Model.TotalPages > 1)
      {
        <div class="join mt-6">
          @for (var p = 1; p <= Model.TotalPages; p++)
          {
            if (p == Model.Page)
            {
              <button class="join-item btn btn-sm btn-primary" disabled>@p</button>
            }
            else
            {
              <a class="join-item btn btn-sm" href="?page=@p">@p</a>
            }
          }
        </div>
      }
    }
  </div>
</section>