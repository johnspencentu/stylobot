@model Stylobot.Website.Portal.LicenseIssuedViewModel
@{
    ViewData["Title"] = "License issued";
}

<section class="min-h-[70vh] px-6 py-16">
  <div class="max-w-3xl mx-auto">
    <a class="btn btn-ghost btn-sm mb-4" href="/portal/org/@Model.Org.Slug">← @Model.Org.Name</a>

    <div class="text-xs uppercase tracking-widest text-success">License issued</div>
    <h1 class="text-3xl font-semibold mt-1">
      @Model.License.Tier.ToUpper() - @(Model.License.IsTrial ? "30-day trial" : "paid") active
    </h1>
    <p class="text-base-content/80 mt-3">
      Copy the token below into your control plane's config under
      <code>BotDetection:Commercial:LicenseToken</code>, or download the <code>.license</code> file
      and mount it via <code>Portal:License:PrivateKeyFilePath</code>. The token is Ed25519-signed;
      your control plane validates it against the vendor public key baked into the release.
    </p>

    <div class="mt-8">
      <label class="label"><span class="label-text font-medium">License token</span></label>
      <textarea id="license-token" class="textarea textarea-bordered w-full font-mono text-xs" rows="10" readonly>@Model.License.SignedToken</textarea>
      <div class="flex gap-2 mt-3">
        <button class="btn btn-primary" type="button" onclick="copyToken()">Copy to clipboard</button>
        <a class="btn btn-outline" href="/portal/org/@Model.Org.Slug/licenses/@Model.License.Id/download">Download .license file</a>
      </div>
    </div>

    <div class="divider"></div>

    <div class="stats stats-vertical sm:stats-horizontal bg-base-200">
      <div class="stat">
        <div class="stat-title">Expires</div>
        <div class="stat-value text-lg">@Model.License.ExpiresAt.ToString("yyyy-MM-dd")</div>
        <div class="stat-desc">@((Model.License.ExpiresAt - DateTime.UtcNow).Days) days</div>
      </div>
      <div class="stat">
        <div class="stat-title">License ID</div>
        <div class="stat-value text-xs font-mono">@Model.License.TokenJti</div>
      </div>
      <div class="stat">
        <div class="stat-title">Features</div>
        <div class="stat-value text-lg">@Model.License.Features.Count</div>
        <div class="stat-desc">flags granted</div>
      </div>
    </div>

    <div class="alert alert-info mt-8">
      <span>
        <strong>Store this token securely.</strong> Anyone with it can activate the tier in a
        StyloBot control plane until it expires or is revoked. We keep the signed copy on our
        side too, so you can re-download anytime from the licenses list.
      </span>
    </div>
  </div>
</section>

<script>
function copyToken() {
  const ta = document.getElementById('license-token');
  ta.select();
  navigator.clipboard.writeText(ta.value).then(() => {
    ta.blur();
    window.getSelection()?.removeAllRanges();
  });
}
</script>