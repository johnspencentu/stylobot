    <!-- SME -->
    <div class="card bg-base-200 p-6 flex flex-col">
      <h2 class="text-lg font-semibold">SME</h2>
      <div class="mt-2"><span class="text-3xl font-bold">$499</span> <span class="text-base-content/60">/ month</span></div>
      <p class="text-sm text-base-content/70 mt-3">Growing mid-market. Multi-region, compliance, SSO at scale.</p>
      <ul class="mt-4 space-y-2 text-sm flex-grow">
        <li>✓ Everything in Startup</li>
        <li>✓ pgvector HNSW session similarity</li>
        <li>✓ 15 gateways, 10 portal users</li>
        <li>✓ Unlimited overrides</li>
        <li>✓ Scheduled reports + CSV/JSON export</li>
        <li>✓ Multi-region, staged rollout, A/B</li>
