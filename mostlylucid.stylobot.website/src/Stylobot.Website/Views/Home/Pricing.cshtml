@{
    ViewData["Title"] = "Pricing — StyloBot";
}

<section class="px-6 py-16">
  <div class="max-w-5xl mx-auto text-center">
    <div class="text-xs uppercase tracking-widest text-base-content/60">Pricing</div>
    <h1 class="text-4xl sm:text-5xl font-semibold mt-2 leading-tight">
      Start on OSS. Upgrade when scale demands it.
    </h1>
    <p class="mt-4 text-lg text-base-content/80 max-w-3xl mx-auto">
      The full detection engine — 31 detectors, behavioral session vectors, local dashboard — is
      OSS under the Unlicense. Pay when you need central control, Postgres durability,
      multi-gateway fleet management, or enterprise SSO. Every deployment stays self-hosted.
    </p>
  </div>
</section>

