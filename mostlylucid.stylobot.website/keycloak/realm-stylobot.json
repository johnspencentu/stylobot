{
  "realm": "stylobot",
  "enabled": true,
  "displayName": "StyloBot Portal",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "loginWithEmailAllowed": true,
  "verifyEmail": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "accessTokenLifespan": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "requiredActions": [
    {
      "alias": "CONFIGURE_TOTP",
      "name": "Configure OTP",
      "providerId": "CONFIGURE_TOTP",
      "enabled": true,
      "defaultAction": false,
      "priority": 10
    }
  ],
  "roles": {
    "realm": [
      { "name": "portal-user", "description": "Signed-up customer portal user" },
      { "name": "portal-admin", "description": "StyloBot staff admin on the portal" }
    ]
  },
  "defaultRoles": ["portal-user", "offline_access", "uma_authorization"],
  "clients": [
    {
      "clientId": "stylobot-portal",
      "name": "StyloBot Portal (stylobot.net)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "dev-portal-secret-change-in-prod",
      "redirectUris": [
        "http://localhost:5062/account/callback",
        "https://localhost:7038/account/callback",
        "https://stylobot.net/account/callback"
      ],
      "webOrigins": [
        "http://localhost:5062",
        "https://localhost:7038",
        "https://stylobot.net"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:5062/*##https://localhost:7038/*##https://stylobot.net/*",
        "backchannel.logout.session.required": "true"
      },
      "defaultClientScopes": [
        "openid",
        "profile",
        "email"
      ]
    }
  ],
  "users": [
    {
      "username": "devuser@stylobot.local",
      "email": "devuser@stylobot.local",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Dev",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "devpass",
          "temporary": false
        }
      ],
      "realmRoles": ["portal-user"]
    }
  ]
}
