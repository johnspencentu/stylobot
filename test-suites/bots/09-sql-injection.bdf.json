{
  "scenarioName": "sql-injection-haxxor",
  "description": "SQL injection + XSS attack patterns. Triggers Haxxor detector. Should get highest risk score.",
  "requests": [
    {
      "method": "GET",
      "path": "/search?q=1' UNION SELECT username,password FROM users--",
      "headers": {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
        "Accept": "*/*"
      },
      "delayAfter": 0.05,
      "expectedDetection": { "isBot": true, "botProbability": 0.98, "riskBand": "VeryHigh" }
    },
    {
      "method": "GET",
      "path": "/api/user?id=1 OR 1=1",
      "headers": {
        "User-Agent": "Mozilla/5.0 (compatible; sqlmap/1.7)"
      },
      "delayAfter": 0.03,
      "expectedDetection": { "isBot": true, "botProbability": 0.98, "riskBand": "VeryHigh" }
    },
    {
      "method": "GET",
      "path": "/page?name=<script>alert('xss')</script>",
      "headers": {
        "User-Agent": "Mozilla/5.0 AppleWebKit/537.36"
      },
      "delayAfter": 0.03,
      "expectedDetection": { "isBot": true, "botProbability": 0.98, "riskBand": "VeryHigh" }
    },
    {
      "method": "GET",
      "path": "/api/data?filter=../../etc/passwd",
      "headers": {
        "User-Agent": "python-requests/2.28.0"
      },
      "delayAfter": 0.0,
      "expectedDetection": { "isBot": true, "botProbability": 0.98, "riskBand": "VeryHigh" }
    }
  ]
}
