{
  "scenarioName": "sequence-api-only-bot",
  "requests": [
    {
      "method": "GET",
      "path": "/api/users",
      "headers": {
        "User-Agent": "python-requests/2.31.0",
        "Accept": "*/*"
      },
      "delayAfter": 0.4,
      "expectedDetection": { "isBot": true, "botProbability": 0.7 }
    },
    {
      "method": "GET",
      "path": "/api/users/1",
      "headers": {
        "User-Agent": "python-requests/2.31.0",
        "Accept": "*/*"
      },
      "delayAfter": 0.4,
      "expectedDetection": { "isBot": true, "botProbability": 0.8 }
    },
    {
      "method": "GET",
      "path": "/api/users/2",
      "headers": {
        "User-Agent": "python-requests/2.31.0",
        "Accept": "*/*"
      },
      "delayAfter": 0.4,
      "expectedDetection": { "isBot": true, "botProbability": 0.8 }
    }
  ]
}
