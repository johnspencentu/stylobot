{
  "scenarioName": "sequence-machine-speed-bot",
  "requests": [
    {
      "method": "GET",
      "path": "/",
      "headers": {
        "User-Agent": "Mozilla/5.0 (compatible; MJ12bot/v1.4.8; http://mj12bot.com/)",
        "Accept": "text/html,*/*",
        "Sec-Fetch-Mode": "navigate",
        "Sec-Fetch-Dest": "document"
      },
      "expectedDetection": { "isBot": true, "botProbability": 0.5 }
    },
    {
      "method": "GET",
      "path": "/api/data",
      "headers": {
        "User-Agent": "Mozilla/5.0 (compatible; MJ12bot/v1.4.8; http://mj12bot.com/)",
        "Accept": "*/*",
        "Sec-Fetch-Mode": "cors",
        "Sec-Fetch-Dest": "empty"
      },
      "delayAfter": 0.003,
      "expectedDetection": { "isBot": true, "botProbability": 0.6 }
    },
    {
      "method": "GET",
      "path": "/api/users",
      "headers": {
        "User-Agent": "Mozilla/5.0 (compatible; MJ12bot/v1.4.8; http://mj12bot.com/)",
        "Accept": "*/*",
        "Sec-Fetch-Mode": "cors",
        "Sec-Fetch-Dest": "empty"
      },
      "delayAfter": 0.002,
      "expectedDetection": { "isBot": true, "botProbability": 0.6 }
    },
    {
      "method": "GET",
      "path": "/api/products",
      "headers": {
        "User-Agent": "Mozilla/5.0 (compatible; MJ12bot/v1.4.8; http://mj12bot.com/)",
        "Accept": "*/*",
        "Sec-Fetch-Mode": "cors",
        "Sec-Fetch-Dest": "empty"
      },
      "delayAfter": 0.004,
      "expectedDetection": { "isBot": true, "botProbability": 0.7 }
    }
  ]
}
