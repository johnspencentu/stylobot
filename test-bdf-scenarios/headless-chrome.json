{
  "scenarioName": "headless-chrome-scraper",
  "requests": [
    {
      "method": "GET",
      "path": "/",
      "headers": {
        "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/120.0.0.0 Safari/537.36",
        "Accept": "text/html",
        "Accept-Language": "en-US",
        "Accept-Encoding": "gzip, deflate, br"
      },
      "expectedDetection": { "isBot": true, "botProbability": 0.8 }
    },
    {
      "method": "GET",
      "path": "/products",
      "headers": {
        "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/120.0.0.0 Safari/537.36",
        "Accept": "text/html"
      },
      "delayAfter": 1.0,
      "expectedDetection": { "isBot": true, "botProbability": 0.8 }
    }
  ]
}
