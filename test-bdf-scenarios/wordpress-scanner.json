{
  "scenarioName": "wordpress-vulnerability-scanner",
  "requests": [
    {
      "method": "GET",
      "path": "/wp-login.php",
      "headers": { "User-Agent": "Mozilla/5.0 (compatible; Scanner/1.0)" },
      "expectedDetection": { "isBot": true, "botProbability": 0.9, "riskBand": "High" }
    },
    {
      "method": "GET",
      "path": "/.env",
      "headers": { "User-Agent": "Mozilla/5.0 (compatible; Scanner/1.0)" },
      "delayAfter": 0.2,
      "expectedDetection": { "isBot": true, "botProbability": 0.9, "riskBand": "High" }
    },
    {
      "method": "GET",
      "path": "/wp-json/wp/v2/users",
      "headers": { "User-Agent": "Mozilla/5.0 (compatible; Scanner/1.0)" },
      "delayAfter": 0.2,
      "expectedDetection": { "isBot": true, "botProbability": 0.9 }
    },
    {
      "method": "POST",
      "path": "/xmlrpc.php",
      "headers": { "User-Agent": "Mozilla/5.0 (compatible; Scanner/1.0)", "Content-Type": "text/xml" },
      "delayAfter": 0.2,
      "expectedDetection": { "isBot": true, "botProbability": 0.9 }
    }
  ]
}
