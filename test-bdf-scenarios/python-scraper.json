{
  "scenarioName": "python-scraper",
  "requests": [
    {
      "method": "GET",
      "path": "/",
      "headers": { "User-Agent": "python-requests/2.31.0", "Accept": "*/*" },
      "expectedDetection": { "isBot": true, "botProbability": 0.9 }
    },
    {
      "method": "GET",
      "path": "/api/products",
      "headers": { "User-Agent": "python-requests/2.31.0", "Accept": "*/*" },
      "delayAfter": 0.5,
      "expectedDetection": { "isBot": true, "botProbability": 0.9 }
    },
    {
      "method": "GET",
      "path": "/api/products/1",
      "headers": { "User-Agent": "python-requests/2.31.0", "Accept": "*/*" },
      "delayAfter": 0.5,
      "expectedDetection": { "isBot": true, "botProbability": 0.9 }
    },
    {
      "method": "GET",
      "path": "/api/products/2",
      "headers": { "User-Agent": "python-requests/2.31.0", "Accept": "*/*" },
      "delayAfter": 0.5,
      "expectedDetection": { "isBot": true, "botProbability": 0.9 }
    }
  ]
}
