<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <LangVersion>preview</LangVersion>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>

        <IsPackable>true</IsPackable>
        <PackageId>mostlylucid.botdetection</PackageId>
        <Authors>Scott Galloway</Authors>
        <PackageIcon>icon.png</PackageIcon>
        <RepositoryUrl>https://github.com/scottgal/stylobot</RepositoryUrl>
        <PackageLicenseExpression>Unlicense</PackageLicenseExpression>
        <PackageTags>bot-detection;middleware;aspnetcore;security;crawler;web</PackageTags>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <Description>
            Bot detection middleware for ASP.NET Core applications with behavioral analysis, header inspection, IP-based detection, and optional LLM-based classification.
        </Description>
        <PackageReleaseNotes>$([System.IO.File]::ReadAllText("$(MSBuildProjectDirectory)/ReleaseNotes.txt"))</PackageReleaseNotes>
        <TargetFrameworks>net10.0</TargetFrameworks>
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>

        <!-- Not AOT/trimming compatible due to SQLite and dynamic JSON usage -->
        <IsTrimmable>false</IsTrimmable>
        <NoWarn>$(NoWarn);IL2026;IL3050</NoWarn>
        <!-- Third-party YAML generator currently throws CS8785 under the preview toolchain,
             but generated output is not required for the runtime manifest parser. -->
        <NoWarn>$(NoWarn);CS8785</NoWarn>
        <UserSecretsId>0c2c1992-7d5d-4581-ada1-8af3d1aee8fc</UserSecretsId>
    </PropertyGroup>
    <PropertyGroup>
        <MinVerTagPrefix>botdetection-v</MinVerTagPrefix>
    </PropertyGroup>
    <ItemGroup>
        <InternalsVisibleTo Include="Mostlylucid.BotDetection.Test" />
        <InternalsVisibleTo Include="Mostlylucid.BotDetection.Orchestration.Tests" />
        <InternalsVisibleTo Include="Mostlylucid.BotDetection.Benchmarks" />
    </ItemGroup>
    <PropertyGroup>
        <MinVerSkip Condition="'$(Configuration)' == 'Debug'">true</MinVerSkip>
    </PropertyGroup>

    <ItemGroup>
        <FrameworkReference Include="Microsoft.AspNetCore.App" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="AngleSharp" Version="1.4.0" />
        <!-- LLM packages moved to Mostlylucid.BotDetection.Llm.Ollama / LlamaSharp projects -->
        <PackageReference Include="Microsoft.Data.Sqlite" Version="10.0.6" />
        <PackageReference Include="SQLitePCLRaw.bundle_e_sqlite3" Version="3.0.2" />
        <PackageReference Include="System.IO.Hashing" Version="10.0.6" />
        <!-- StyloFlow: NuGet package references -->
        <PackageReference Include="Mostlylucid.StyloFlow.Core" Version="2.4.0" />
        <PackageReference Include="Mostlylucid.StyloFlow.Retrieval.Core" Version="2.4.0" />
        <!-- Ephemeral: Core signal/coordination infrastructure (NuGet packages) -->
        <PackageReference Include="Mostlylucid.Ephemeral" Version="2.3.2" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.Taxonomy" Version="2.3.2" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.KeyedSequential" Version="2.3.2" />
        <PackageReference Include="Mostlylucid.Ephemeral.Atoms.SlidingCache" Version="2.3.2" />
        <PackageReference Include="HNSW" Version="26.4.177" />
        <PackageReference Include="Qdrant.Client" Version="1.17.0" />
        <PackageReference Include="Microsoft.ML.OnnxRuntime" Version="1.24.4" />
        <PackageReference Include="Microsoft.ML.Tokenizers" Version="2.0.0" />
        <PackageReference Include="System.Numerics.Tensors" Version="10.0.6" />
        <PackageReference Include="MathNet.Numerics" Version="5.0.0" />
        <PackageReference Include="Microsoft.Recognizers.Text" Version="1.8.13" />
        <PackageReference Include="Microsoft.Recognizers.Text.DateTime" Version="1.8.13" />
        <PackageReference Include="Microsoft.Recognizers.Text.Sequence" Version="1.8.13" />
        <!-- Override transitive NuGet.CommandLine pulled in by Microsoft.Recognizers.Text 1.8.13
             (it drags in 5.11.5 which has a critical GHSA-68w7-72jg-6qpp advisory). NuGet.CommandLine
             is a build-tool binary we don't execute at runtime; pinning to 7.3.1 clears the alert
             without affecting any shipped code. PrivateAssets=all stops this leaking into consumers. -->
        <PackageReference Include="NuGet.CommandLine" Version="7.3.1" PrivateAssets="all" />
        <PackageReference Include="YamlDotNet" Version="16.3.0" />
        <PackageReference Include="Vecc.YamlDotNet.Analyzers.StaticGenerator" Version="16.3.0">
            <PrivateAssets>all</PrivateAssets>
            <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
        </PackageReference>
        <PackageReference Include="MinVer" Version="7.0.0">
            <PrivateAssets>all</PrivateAssets>
            <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
        </PackageReference>
    </ItemGroup>

    <ItemGroup>
        <None Include="ReleaseNotes.txt" />
        <Content Include="docs\ai-detection.md" />
    </ItemGroup>

    <!-- Embed JS files as resources for TagHelper -->
    <ItemGroup>
        <EmbeddedResource Include="ClientSide\botdetection.js" />
    </ItemGroup>

    <!-- Embed policy definition YAML files -->
    <ItemGroup>
        <EmbeddedResource Include="Definitions\Actions\*.yaml" />
    </ItemGroup>

    <!-- Embed detector and pipeline YAML manifests -->
    <ItemGroup>
        <EmbeddedResource Include="Orchestration\Manifests\detectors\*.yaml" />
        <EmbeddedResource Include="Orchestration\Manifests\pipelines\*.yaml" />
        <EmbeddedResource Include="Orchestration\Manifests\entities\*.yaml" />
        <EmbeddedResource Include="Orchestration\Manifests\schemas\*.json" />
        <EmbeddedResource Include="Orchestration\Manifests\proxy-headers.yaml" />
    </ItemGroup>

    <!-- Embed simulation pack YAML definitions -->
    <ItemGroup>
        <EmbeddedResource Include="SimulationPacks\Packs\*.yaml" />
    </ItemGroup>

    <!-- Embed compliance pack YAML definitions -->
    <ItemGroup>
        <EmbeddedResource Include="Compliance\CompliancePacks\*.yaml" />
    </ItemGroup>

    <!-- Include icon and README in NuGet package -->
    <ItemGroup>
        <None Include=".\icon.png" Pack="true" PackagePath="">
            <Link>Properties\icon.png</Link>
        </None>
        <None Include=".\README.md" Pack="true" PackagePath="">
            <Link>Properties\README.md</Link>
        </None>
    </ItemGroup>

    <!-- Exclude docs folder from NuGet package -->
    <ItemGroup>
        <Content Remove="docs\**" />
    </ItemGroup>
</Project>
