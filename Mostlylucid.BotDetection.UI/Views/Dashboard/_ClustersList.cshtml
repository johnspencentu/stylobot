@using Mostlylucid.BotDetection.UI.Models
@model ClustersListModel
<div id="clusters-list"
     data-sb-widget="clusters"
     data-sb-depends="clusters"
     class="transition-all duration-200">
    @if (Model.Diagnostics != null)
    {
        <div class="rounded-xl border p-3 mb-4" style="border-color: var(--sb-card-border); background: var(--sb-card-bg);">
            <div class="flex items-center justify-between gap-3">
                <div>
                    <div class="text-[10px] uppercase tracking-wider text-base-content/40">Cluster Engine</div>
                    <div class="text-sm font-bold">@Model.Diagnostics.Algorithm</div>
                    <div class="text-xs text-base-content/50">@Model.Diagnostics.Status</div>
                </div>
                <div class="text-right text-xs text-base-content/60">
                    <div>@Model.Diagnostics.InputBehaviorCount signatures</div>
                    <div>@Model.Diagnostics.ClusterCount clusters</div>
                    <div>density @((Model.Diagnostics.GraphDensity * 100).ToString("F0"))%</div>
                </div>
            </div>
            <div class="grid grid-cols-3 md:grid-cols-6 gap-2 mt-3 text-center">
                <div><div class="text-sm font-bold">@Model.Diagnostics.MachineClusterCount</div><div class="text-[10px] text-base-content/40">Machine</div></div>
                <div><div class="text-sm font-bold">@Model.Diagnostics.HumanClusterCount</div><div class="text-[10px] text-base-content/40">Human</div></div>
                <div><div class="text-sm font-bold">@Model.Diagnostics.MixedClusterCount</div><div class="text-[10px] text-base-content/40">Mixed</div></div>
                <div><div class="text-sm font-bold">@Model.Diagnostics.RawCommunityCount</div><div class="text-[10px] text-base-content/40">Communities</div></div>
                <div><div class="text-sm font-bold">@Model.Diagnostics.SimilarityThreshold.ToString("F2")</div><div class="text-[10px] text-base-content/40">Threshold</div></div>
                <div><div class="text-sm font-bold">@Model.Diagnostics.MinClusterSize</div><div class="text-[10px] text-base-content/40">Min Size</div></div>
            </div>
            @if (Model.Diagnostics.TopWeights.Count > 0)
            {
                <div class="mt-3">
                    <div class="text-[10px] uppercase tracking-wider text-base-content/40 mb-1">Top Markov / Cluster Weights</div>
                    <div class="flex flex-wrap gap-1">
                        @foreach (var weight in Model.Diagnostics.TopWeights)
                        {
                            <span class="text-[10px] px-1.5 py-0.5 rounded bg-base-content/10 text-base-content/70">@weight.Key=@weight.Value.ToString("P0")</span>
                        }
                    </div>
                </div>
            }
        </div>
    }
    @if (Model.Clusters.Count == 0)
    {
        <div class="text-center text-base-content/30 py-12 text-sm">
            No bot clusters detected yet. Clusters form when the Leiden algorithm identifies groups of related bot signatures.
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-3">
            @foreach (var cluster in Model.Clusters)
            {
                var typeClass = cluster.Type switch {
                    "BotProduct" => "badge-error",
                    "BotNetwork" => "badge-error",
                    "Emergent" => "badge-warning",
                    "HumanTraffic" => "badge-success",
                    "Mixed" => "badge-warning",
                    _ => "badge-ghost"
                };
                var threatClass = cluster.AverageThreatScore switch {
                    > 7 => "text-error",
                    > 4 => "text-warning",
                    _ => "text-success"
                };
                <div class="card bg-base-200 hover:bg-base-300 transition-all duration-200">
                    <div class="card-body p-3 gap-1">
                        <div class="flex items-center justify-between">
                            <span class="text-sm font-bold truncate">@cluster.Label</span>
                            <span class="badge badge-xs @typeClass">@cluster.Type</span>
                        </div>
                        @if (!string.IsNullOrEmpty(cluster.Description))
                        {
                            <p class="text-[11px] text-base-content/60 line-clamp-2">@cluster.Description</p>
                        }
                        <div class="grid grid-cols-3 gap-1 mt-1 text-center text-[10px]">
                            <div>
                                <div class="font-bold text-sm">@cluster.MemberCount</div>
                                <div class="text-base-content/40">Members</div>
                            </div>
                            <div>
                                <div class="font-bold text-sm @(cluster.AvgBotProb > 0.8 ? "text-error" : "text-warning")">
                                    @((cluster.AvgBotProb * 100).ToString("F0"))%
                                </div>
                                <div class="text-base-content/40">Avg Prob</div>
                            </div>
                            <div>
                                <div class="font-bold text-sm @threatClass">@cluster.AverageThreatScore.ToString("F1")</div>
                                <div class="text-base-content/40">Threat</div>
                            </div>
                        </div>
                        <div class="flex items-center gap-2 mt-1 text-[10px] text-base-content/40">
                            @if (!string.IsNullOrEmpty(cluster.Country))
                            {
                                <span>@cluster.Country</span>
                            }
                            <span>Sim: @((cluster.AverageSimilarity * 100).ToString("F0"))%</span>
                            @if (!string.IsNullOrEmpty(cluster.DominantIntent))
                            {
                                <span>@cluster.DominantIntent</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
