@model Mostlylucid.BotDetection.UI.Models.InvestigationViewModel
@{
    var fpSignals = new Dictionary<string, List<string>>();
    foreach (var d in Model.Result.Detections)
    {
        if (d.ImportantSignals == null) continue;
        foreach (var (key, val) in d.ImportantSignals.Where(kv => kv.Key.StartsWith("fp.") || kv.Key.StartsWith("tls.") || kv.Key.StartsWith("http.")))
        {
            if (!fpSignals.ContainsKey(key)) fpSignals[key] = new List<string>();
            fpSignals[key].Add(val?.ToString() ?? "null");
        }
    }
}

<div class="sb-investigate-fingerprints">
    @if (!fpSignals.Any())
    {
        <p style="color:var(--sb-brand-muted); padding:1rem;">No fingerprint data available for this result set.</p>
    }
    else
    {
        <table style="width:100%; border-collapse:collapse; font-size:0.85rem;">
            <thead>
                <tr style="border-bottom:2px solid var(--sb-card-border); text-align:left;">
                    <th style="padding:0.5rem;">Signal</th>
                    <th style="padding:0.5rem;">Values Seen</th>
                    <th style="padding:0.5rem;">Consistency</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var (key, values) in fpSignals.OrderBy(kv => kv.Key))
                {
                    var distinct = values.Distinct().ToList();
                    var isConsistent = distinct.Count == 1;
                    <tr style="border-bottom:1px solid var(--sb-card-divider);">
                        <td style="padding:0.5rem; font-family:monospace; font-size:0.8rem;">@key</td>
                        <td style="padding:0.5rem;">
                            @foreach (var v in distinct.Take(5))
                            {
                                <span style="padding:0.1rem 0.4rem; background:var(--sb-surface); border-radius:3px; margin-right:0.25rem; font-size:0.75rem;">@v</span>
                            }
                            @if (distinct.Count > 5) { <span style="font-size:0.75rem; color:var(--sb-brand-muted);">+@(distinct.Count - 5) more</span> }
                        </td>
                        <td style="padding:0.5rem;">
                            @if (isConsistent)
                            {
                                <span style="color:var(--sb-signal-pos);">consistent</span>
                            }
                            else
                            {
                                <span style="color:var(--sb-signal-warn);">@distinct.Count variants</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
