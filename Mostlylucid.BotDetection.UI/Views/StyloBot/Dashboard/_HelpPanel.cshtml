@model Mostlylucid.BotDetection.UI.Services.HelpEntry
<div id="help-panel"
     style="position:fixed; top:0; right:0; width:min(480px, 90vw); height:100vh; background:var(--sb-card-bg, oklch(var(--b1))); border-left:1px solid var(--sb-card-border, oklch(var(--b3))); box-shadow:-4px 0 20px rgba(0,0,0,0.15); z-index:9999; display:flex; flex-direction:column; overflow:hidden;">

    <!-- Header -->
    <div style="display:flex; align-items:center; justify-content:space-between; padding:0.75rem 1rem; border-bottom:1px solid var(--sb-card-border, oklch(var(--b3))); flex-shrink:0;">
        <h3 style="font-size:0.95rem; font-weight:600; margin:0;">
            <i class="bx bx-help-circle" style="margin-right:0.3rem; vertical-align:middle;"></i>
            @Model.Title
        </h3>
        <button onclick="document.getElementById('help-panel')?.remove()"
                style="background:none; border:none; cursor:pointer; padding:0.25rem; font-size:1.2rem; color:inherit; opacity:0.5;"
                title="Close help">
            <i class="bx bx-x"></i>
        </button>
    </div>

    <!-- Content -->
    <div style="flex:1; overflow-y:auto; padding:1rem; font-size:0.85rem; line-height:1.6;"
         class="prose prose-sm max-w-none">
        @Html.Raw(Model.Html)
    </div>

    <!-- Footer -->
    <div style="padding:0.5rem 1rem; border-top:1px solid var(--sb-card-border, oklch(var(--b3))); font-size:0.7rem; color:var(--sb-brand-muted, oklch(var(--bc)/0.5)); flex-shrink:0; text-align:center;">
        Press Escape to close -- <a href="https://stylobot.net/docs" target="_blank" style="text-decoration:underline;">Full documentation</a>
    </div>
</div>

<script nonce="">
    // Close on Escape key
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') document.getElementById('help-panel')?.remove();
    });
    // Close on click outside
    document.getElementById('help-panel')?.addEventListener('click', function(e) {
        if (e.target === this) this.remove();
    });
</script>
