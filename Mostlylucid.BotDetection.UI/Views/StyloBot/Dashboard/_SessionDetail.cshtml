@using Mostlylucid.BotDetection.UI.Models
@model SessionDetailModel
@{
    var bp = Model.BasePath;

    string RiskColor(string risk) => risk switch {
        "VeryHigh" => "text-error",
        "High" => "text-warning",
        "Medium" => "text-info",
        "Low" => "text-success",
        "VeryLow" => "text-base-content/40",
        _ => ""
    };

    // Build the radar chart data from transition counts
    var states = new[] { "Page", "Api", "Asset", "WS", "SignalR", "SSE", "Form", "Auth", "404", "Search" };
    var stateValues = new double[states.Length];
    if (Model.TransitionCounts != null)
    {
        // Count outbound transitions per state
        foreach (var kv in Model.TransitionCounts)
        {
            var from = kv.Key.Split("->")[0];
            for (var i = 0; i < states.Length; i++)
            {
                if (from.StartsWith(states[i], StringComparison.OrdinalIgnoreCase))
                {
                    stateValues[i] += kv.Value;
                    break;
                }
            }
        }
        // Normalize to 0-100
        var max = stateValues.Max();
        if (max > 0) for (var i = 0; i < stateValues.Length; i++) stateValues[i] = Math.Round(stateValues[i] / max * 100, 1);
    }
    var radarLabels = System.Text.Json.JsonSerializer.Serialize(states);
    var radarValues = System.Text.Json.JsonSerializer.Serialize(stateValues);
}

<div class="card bg-base-100 border border-base-300">
    <div class="card-body p-4">
        @* Header *@
        <div class="flex items-center justify-between mb-3">
            <div>
                <h4 class="text-sm font-bold text-base-content">Session Detail</h4>
                <p class="text-[10px] text-base-content/40">
                    @Model.StartedAt.ToString("MMM dd HH:mm") - @Model.EndedAt.ToString("HH:mm")
                    (@Model.DurationMinutes.ToString("F1") min)
                </p>
            </div>
            <a href="@bp/signature/@Uri.EscapeDataString(Model.Signature)"
               class="btn btn-xs btn-ghost">View Signature &rarr;</a>
        </div>

        @* Stats grid *@
        <div class="grid grid-cols-4 gap-2 mb-3">
            <div class="bg-base-200 rounded p-2 text-center">
                <div class="text-lg font-bold">@Model.RequestCount</div>
                <div class="text-[10px] text-base-content/50">Requests</div>
            </div>
            <div class="bg-base-200 rounded p-2 text-center">
                <div class="text-lg font-bold @RiskColor(Model.RiskBand)">
                    @((Model.AvgBotProbability * 100).ToString("F0"))%
                </div>
                <div class="text-[10px] text-base-content/50">Bot Prob</div>
            </div>
            <div class="bg-base-200 rounded p-2 text-center">
                <div class="text-lg font-bold">@Model.ErrorCount</div>
                <div class="text-[10px] text-base-content/50">Errors</div>
            </div>
            <div class="bg-base-200 rounded p-2 text-center">
                <div class="text-lg font-bold">@Model.TimingEntropy.ToString("F1")</div>
                <div class="text-[10px] text-base-content/50">Entropy</div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
            @* Left: Behavioral Radar (session vector shape) *@
            <div>
                <h5 class="text-xs font-semibold mb-1 text-base-content/70">Behavioral Shape</h5>
                <div class="bg-base-200 rounded p-2" style="height: 220px;">
                    <canvas id="session-radar-@Model.Id"></canvas>
                </div>
            </div>

            @* Right: Markov chain transitions *@
            <div>
                <h5 class="text-xs font-semibold mb-1 text-base-content/70">Request Chain</h5>
                @if (Model.TransitionCounts != null && Model.TransitionCounts.Count > 0)
                {
                    <div class="bg-base-200 rounded p-2 space-y-1 max-h-52 overflow-y-auto">
                        @foreach (var t in Model.TransitionCounts.OrderByDescending(kv => kv.Value))
                        {
                            var parts = t.Key.Split("->");
                            var pct = Model.TransitionCounts.Values.Sum() > 0
                                ? (double)t.Value / Model.TransitionCounts.Values.Sum() * 100 : 0;
                            <div class="flex items-center gap-2 text-[11px]">
                                <span class="w-20 text-right font-mono truncate" title="@parts[0]">@parts[0]</span>
                                <span class="text-base-content/30">&rarr;</span>
                                <span class="w-20 font-mono truncate" title="@parts[1]">@parts[1]</span>
                                <div class="flex-1 bg-base-300 rounded-full h-2">
                                    <div class="bg-primary rounded-full h-2" style="width: @pct.ToString("F0")%"></div>
                                </div>
                                <span class="text-base-content/50 w-8 text-right">@t.Value</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-xs text-base-content/40 py-4 text-center">No transitions recorded</div>
                }
            </div>
        </div>

        @* Paths visited *@
        @if (Model.Paths != null && Model.Paths.Count > 0)
        {
            <div class="mt-3">
                <h5 class="text-xs font-semibold mb-1 text-base-content/70">Paths Visited (@Model.Paths.Count)</h5>
                <div class="flex flex-wrap gap-1">
                    @foreach (var path in Model.Paths.Take(20))
                    {
                        <span class="badge badge-sm badge-ghost font-mono text-[10px]">@path</span>
                    }
                    @if (Model.Paths.Count > 20)
                    {
                        <span class="badge badge-sm badge-ghost text-[10px]">+@(Model.Paths.Count - 20) more</span>
                    }
                </div>
            </div>
        }

        @* Maturity indicator *@
        <div class="mt-2 flex items-center gap-2 text-[10px] text-base-content/40">
            <span>Vector maturity:</span>
            <progress class="progress progress-primary w-20 h-1" value="@((int)(Model.Maturity * 100))" max="100"></progress>
            <span>@((Model.Maturity * 100).ToString("F0"))%</span>
        </div>
    </div>
</div>

@* Radar chart initialization *@
<script nonce="@Model.CspNonce">
(function() {
    var ctx = document.getElementById('session-radar-@Model.Id');
    if (!ctx || typeof ApexCharts === 'undefined') return;

    var labels = @Html.Raw(radarLabels);
    var values = @Html.Raw(radarValues);

    new ApexCharts(ctx, {
        series: [{ name: 'Activity', data: values }],
        chart: { type: 'radar', height: 200, toolbar: { show: false },
                 background: 'transparent', fontFamily: 'Inter, sans-serif' },
        xaxis: { categories: labels },
        yaxis: { show: false },
        fill: { opacity: 0.3 },
        stroke: { width: 2 },
        markers: { size: 2 },
        colors: ['hsl(var(--p))'],
        plotOptions: { radar: { polygons: { strokeColors: 'hsl(var(--bc) / 0.1)',
                                            connectorColors: 'hsl(var(--bc) / 0.1)' } } },
        theme: { mode: document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light' }
    }).render();
})();
</script>
