@using Mostlylucid.BotDetection.UI.Models
@model DashboardShellModel
@{
    Layout = null;
    var bp = Model.BasePath;
    var tab = Model.ActiveTab;
    string TabUrl(string t) => $"{bp}?tab={t}";
    string TabClass(string t) => tab == t
        ? "bg-base-100 shadow-sm text-base-content font-semibold"
        : "text-base-content/40 hover:text-base-content/60";
}
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>StyloBot Detection Dashboard</title>
    <!-- All assets self-hosted -- zero external requests (security product) -->
    <link rel="stylesheet" href="/_content/Mostlylucid.BotDetection.UI/vendor/css/tailwind.min.css" />
    <link rel="stylesheet" href="/_content/Mostlylucid.BotDetection.UI/vendor/css/jsvectormap.min.css" />
    <link rel="stylesheet" href="/_content/Mostlylucid.BotDetection.UI/vendor/css/boxicons.min.css" />
    <link rel="stylesheet" href="/_content/Mostlylucid.BotDetection.UI/vendor/css/fonts.css" />
    <script src="/_content/Mostlylucid.BotDetection.UI/vendor/js/htmx.min.js" nonce="@Model.CspNonce"></script>
    <script src="/_content/Mostlylucid.BotDetection.UI/vendor/js/signalr.min.js" nonce="@Model.CspNonce"></script>
    <script defer src="/_content/Mostlylucid.BotDetection.UI/vendor/js/alpine.min.js" nonce="@Model.CspNonce"></script>
    <script src="/_content/Mostlylucid.BotDetection.UI/vendor/js/jsvectormap.min.js" nonce="@Model.CspNonce"></script>
    <script src="/_content/Mostlylucid.BotDetection.UI/vendor/js/world-merc.js" nonce="@Model.CspNonce"></script>
    <script src="/_content/Mostlylucid.BotDetection.UI/vendor/js/apexcharts.min.js" nonce="@Model.CspNonce"></script>

    <script nonce="@Model.CspNonce">
        (function() {
            try {
                var saved = localStorage.getItem('sb-theme');
                if (saved) document.documentElement.setAttribute('data-theme', saved);
                else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches)
                    document.documentElement.setAttribute('data-theme', 'light');
            } catch(e) {}
            if (new URLSearchParams(window.location.search).get('embed') === '1') {
                document.addEventListener('DOMContentLoaded', function() {
                    var hdr = document.getElementById('sb-brand-header');
                    if (hdr) hdr.style.display = 'none';
                });
            }
        })();
    </script>

    <style nonce="@Model.CspNonce">
        [x-cloak] { display: none !important; }
        [data-theme="dark"] {
            --sb-brand-muted: #6b7280;
            --sb-brand-strong: #ffffff;
            --sb-accent: #5ba3a3;
            --sb-accent-alt: #0f4c81;
            --sb-accent-strong: #86b59c;
            --sb-surface: #0b1220;
            --sb-card-bg: #141f33;
            --sb-card-border: rgba(91, 163, 163, 0.28);
            --sb-card-divider: rgba(148, 163, 184, 0.18);
            --sb-card-subtle: #334155;
            --sb-signal-pos: #86B59C;
            --sb-signal-warn: #DAA564;
            --sb-signal-danger: #ef4444;
        }
        [data-theme="light"] {
            --sb-brand-muted: #475569;
            --sb-brand-strong: #0f172a;
            --sb-accent: #0f766e;
            --sb-accent-alt: #0f4c81;
            --sb-accent-strong: #059669;
            --sb-surface: #f8fafc;
            --sb-card-bg: #ffffff;
            --sb-card-border: rgba(15, 118, 110, 0.18);
            --sb-card-divider: rgba(15, 23, 42, 0.1);
            --sb-card-subtle: #94a3b8;
            --sb-signal-pos: #16a34a;
            --sb-signal-warn: #d97706;
            --sb-signal-danger: #dc2626;
        }

        body { font-family: 'Inter', sans-serif; background: var(--sb-surface); }
        .brand-header {
            background: linear-gradient(120deg, color-mix(in oklab, var(--sb-surface) 78%, #0f172a), color-mix(in oklab, var(--sb-card-bg) 70%, #0f172a));
            border-bottom: 1px solid var(--sb-card-divider);
        }
        .sb-link { color: var(--sb-accent); text-decoration: none; }
        .sb-link:hover { text-decoration: underline; }

        /* HTMX transition styles */
        .htmx-swapping { opacity: 0; transition: opacity 200ms ease-out; }
        .htmx-settling { opacity: 1; transition: opacity 200ms ease-in; }
        .htmx-added { opacity: 0; }
        .htmx-added.htmx-settling { opacity: 1; transition: opacity 300ms ease-in; }

        /* Connection status indicator */
        .sb-connected { background: var(--sb-signal-pos); }
        .sb-disconnected { background: var(--sb-signal-danger); }
        .sb-connecting { background: var(--sb-signal-warn); animation: pulse 1.5s infinite; }
        @@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
    </style>
</head>
<body class="min-h-screen overflow-x-hidden" hx-headers='{"X-Requested-With": "XMLHttpRequest"}'>

    <!-- Brand header -->
    <header id="sb-brand-header" class="brand-header px-4 py-3">
        <div class="max-w-7xl mx-auto flex items-center justify-between">
            <div class="flex items-center gap-3">
                <a href="@bp" class="text-lg font-black tracking-tight" style="font-family: 'Raleway', sans-serif;">
                    <span style="color: var(--sb-brand-muted);">stylo</span><span style="color: var(--sb-brand-strong);">bot</span>
                </a>
                <span class="text-xs font-medium px-2 py-0.5 rounded-full"
                      style="background: var(--sb-card-bg); color: var(--sb-brand-muted); border: 1px solid var(--sb-card-border);">
                    Dashboard
                </span>
                <!-- SignalR connection status -->
                <span id="sb-connection-status" class="w-2 h-2 rounded-full sb-disconnected" title="SignalR: disconnected"></span>
                @if (Model.License.Status == LicenseStatusKind.Unconfigured)
                {
                    <span class="text-[10px] text-base-content/40 ml-2">OSS tier</span>
                    <a href="https://stylobot.net/pricing" target="_blank" rel="noopener"
                       class="text-[10px] text-base-content/30 hover:text-base-content/60 ml-1">
                        Compare paid tiers →
                    </a>
                }
            </div>
            <div class="flex items-center gap-2">
                <button onclick="document.documentElement.setAttribute('data-theme', document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark'); try { localStorage.setItem('sb-theme', document.documentElement.getAttribute('data-theme')); } catch(e) {}"
                        class="btn btn-ghost btn-xs btn-circle">
                    <i class="bx bx-moon text-sm"></i>
                </button>
            </div>
        </div>
    </header>

    <!-- Main content -->
    <main class="max-w-7xl mx-auto px-2 py-4">

        <!-- Summary stats - always visible -->
        @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_SummaryStats.cshtml", Model.Summary)

        <!-- License + Your Detection -->
        @if (Model.License.Status != LicenseStatusKind.Unconfigured)
        {
            <!-- Licensed: two-column layout with license details -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 my-4">
                <div>
                    @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_LicenseCard.cshtml", Model.License)
                </div>
                <div>
                    @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_YourDetection.cshtml", Model.YourDetection)
                </div>
            </div>
        }
        else
        {
            <!-- OSS: full-width Your Detection (license reminder is in header) -->
            <div class="my-4">
                @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_YourDetection.cshtml", Model.YourDetection)
            </div>
        }

        <!-- Tab navigation -->
        <div class="flex items-center gap-1 my-4 bg-base-300/50 rounded-lg p-0.5 w-fit">
            <a href="@TabUrl("overview")" class="px-3 py-1.5 text-xs font-medium rounded-md transition-all @TabClass("overview")">Overview</a>
            <a href="@TabUrl("activity")" class="px-3 py-1.5 text-xs font-medium rounded-md transition-all @TabClass("activity")">Activity</a>
            <a href="@TabUrl("visitors")" class="px-3 py-1.5 text-xs font-medium rounded-md transition-all @TabClass("visitors")">Visitors</a>
            <a href="@TabUrl("countries")" class="px-3 py-1.5 text-xs font-medium rounded-md transition-all @TabClass("countries")">Countries</a>
            <a href="@TabUrl("endpoints")" class="px-3 py-1.5 text-xs font-medium rounded-md transition-all @TabClass("endpoints")">Endpoints</a>
            <a href="@TabUrl("sessions")" class="px-3 py-1.5 text-xs font-medium rounded-md transition-all @TabClass("sessions")">Sessions</a>
            <a href="@TabUrl("clusters")" class="px-3 py-1.5 text-xs font-medium rounded-md transition-all @TabClass("clusters")">Clusters</a>
            <a href="@TabUrl("threats")" class="px-3 py-1.5 text-xs font-medium rounded-md transition-all @TabClass("threats")">Threats</a>
            <a href="@TabUrl("useragents")" class="px-3 py-1.5 text-xs font-medium rounded-md transition-all @TabClass("useragents")">User Agents</a>
            @if (Model.IsCommercial)
            {
                <a href="@TabUrl("compliance")" class="px-3 py-1.5 text-xs font-medium rounded-md transition-all @TabClass("compliance")">Compliance</a>
                <a href="@TabUrl("configuration")" class="px-3 py-1.5 text-xs font-medium rounded-md transition-all @TabClass("configuration")">Configuration</a>
                <a href="@TabUrl("investigate")" class="px-3 py-1.5 text-xs font-medium rounded-md transition-all @TabClass("investigate")">Investigate</a>
            }
        </div>

        @if (Model.StatusStrip is not null)
        {
            @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_StatusStrip.cshtml", Model.StatusStrip)
        }

        @if (tab == "overview")
        {
            var highRiskEndpoints = Model.Endpoints.Endpoints.Count(e => e.BotRate > 0.5 && e.TotalCount >= 5);
            var botPct = Model.Summary.Summary.BotPercentage;
            var activeBotCount = Model.TopBots.TotalCount;

            @if (highRiskEndpoints > 0 || botPct > 30 || activeBotCount > 0)
            {
                <div class="flex flex-wrap items-center gap-x-4 gap-y-1 px-4 py-2.5 mb-4 rounded-xl text-xs"
                     style="background: color-mix(in oklab, var(--sb-signal-danger) 10%, var(--sb-card-bg)); border: 1px solid color-mix(in oklab, var(--sb-signal-danger) 25%, transparent);">
                    <i class="bx bx-shield-x text-error text-base shrink-0"></i>
                    @if (highRiskEndpoints > 0)
                    {
                        <span><span class="font-bold text-error">@highRiskEndpoints</span> endpoint@(highRiskEndpoints != 1 ? "s" : "") under high bot pressure</span>
                        <span class="text-base-content/20">|</span>
                    }
                    @if (activeBotCount > 0)
                    {
                        <span><span class="font-bold">@activeBotCount</span> bot signature@(activeBotCount != 1 ? "s" : "") active</span>
                    }
                    @if (botPct > 10)
                    {
                        <span class="text-base-content/20">|</span>
                        <span class="@(botPct > 30 ? "text-error font-bold" : "")">@botPct.ToString("F0")% bot traffic</span>
                    }
                    <a href="@TabUrl("threats")" class="ml-auto text-base-content/50 hover:text-base-content">Threats →</a>
                </div>
            }

            <!-- Primary ops view: Endpoints by bot pressure + Active bots -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">

                <!-- ENDPOINTS BY BOT PRESSURE: 2/3 width -->
                <div class="lg:col-span-2">
                    <div id="overview-endpoints"
                         hx-get="@bp/partials/endpoints?pageSize=10&excludeStatic=true&sort=botrate&dir=desc"
                         hx-trigger="load, every 15s"
                         hx-swap="innerHTML"
                         class="rounded-xl border overflow-hidden"
                         style="border-color: var(--sb-card-border); background: var(--sb-card-bg);">
                        <div class="flex items-center justify-between px-3 py-1.5 border-b" style="border-color: var(--sb-card-divider);">
                            <div class="flex items-center gap-2">
                                <span class="text-[10px] font-semibold text-base-content/70">ENDPOINTS BY BOT PRESSURE</span>
                                <span class="text-[9px] px-1 py-0.5 rounded bg-error/20 text-error font-medium">LIVE</span>
                            </div>
                            <a href="@TabUrl("endpoints")" class="text-[9px] text-base-content/40 hover:text-base-content/60">All endpoints →</a>
                        </div>
                        <div class="p-2 text-xs text-base-content/40 text-center py-4">Loading...</div>
                    </div>
                </div>

                <!-- ACTIVE BOTS: 1/3 width -->
                <div>
                    @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_TopBotsList.cshtml", Model.TopBots)
                </div>
            </div>

            <!-- Traffic chart + World map -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mt-4">

                <div class="rounded-xl border overflow-hidden" style="border-color: var(--sb-card-border); background: var(--sb-card-bg);">
                    <div class="flex items-center justify-between px-3 py-1.5 border-b" style="border-color: var(--sb-card-divider);">
                        <div class="flex items-center gap-1">
                            <span class="text-[10px] font-semibold text-base-content/70">TRAFFIC OVER TIME</span>
                            @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_HelpIcon.cshtml", "traffic-chart")
                        </div>
                        <span class="text-[9px] text-base-content/40">Last 6 hours</span>
                    </div>
                    <div class="p-2">
                        <div id="time-chart" style="height: 140px;"></div>
                    </div>
                </div>

                <div class="rounded-xl border overflow-hidden command-map-container" style="border-color: var(--sb-card-border); background: var(--sb-card-bg);">
                    <div class="flex items-center justify-between px-3 py-1.5 border-b" style="border-color: var(--sb-card-divider);">
                        <div class="flex items-center gap-2">
                            <span class="text-[10px] font-semibold text-base-content/70">GLOBAL THREAT MAP</span>
                            @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_HelpIcon.cshtml", "world-map")
                        </div>
                    </div>
                    <div id="command-map" class="relative" style="height: 280px;"></div>
                </div>
            </div>
        }
        else if (tab == "activity")
        {
            <!-- Full activity view: Recent Activity (large, filtered) + Endpoints (filtered) -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
                <div class="lg:col-span-2">
                    @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_RecentActivity.cshtml", Model.Visitors)
                </div>
                <div>
                    <div id="activity-endpoints"
                         hx-get="@bp/partials/endpoints?pageSize=15&excludeStatic=true&sort=total&dir=desc"
                         hx-trigger="load, every 5s"
                         hx-swap="innerHTML"
                         class="rounded-xl border overflow-hidden"
                         style="border-color: var(--sb-card-border); background: var(--sb-card-bg);">
                        <div class="flex items-center justify-between px-3 py-1.5 border-b" style="border-color: var(--sb-card-divider);">
                            <div class="flex items-center gap-2">
                                <span class="text-[10px] font-semibold text-base-content/70">ACTIVE ENDPOINTS</span>
                                <span class="text-[9px] px-1 py-0.5 rounded status-badge-danger font-medium">LIVE</span>
                            </div>
                        </div>
                        <div class="p-2 text-xs text-base-content/40 text-center py-4">Loading...</div>
                    </div>
                </div>
            </div>
        }
        else if (tab == "visitors")
        {
            @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_VisitorList.cshtml", Model.Visitors)
        }
        else if (tab == "countries")
        {
            <!-- Country map + table -->
            <div class="rounded-xl border overflow-hidden mb-4" style="border-color: var(--sb-card-border); background: var(--sb-card-bg);">
                <div class="flex items-center justify-between px-3 py-1.5 border-b" style="border-color: var(--sb-card-divider);">
                    <div class="flex items-center gap-2">
                        <span class="text-[10px] font-semibold text-base-content/70">GLOBAL THREAT MAP</span>
                        <span class="text-[9px] px-1 py-0.5 rounded status-badge-danger font-medium">LIVE</span>
                    </div>
                </div>
                <div id="countries-map" class="relative" style="height: 440px;"></div>
            </div>
            @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_CountriesList.cshtml", Model.Countries)
        }
        else if (tab == "endpoints")
        {
            @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_EndpointsList.cshtml", Model.Endpoints)
        }
        else if (tab == "sessions")
        {
            @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_SessionsList.cshtml", Model.Sessions)
        }
        else if (tab == "clusters")
        {
            @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_ClustersList.cshtml", Model.Clusters)
        }
        else if (tab == "threats")
        {
            @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_ThreatsList.cshtml", Model.Threats)
        }
        else if (tab == "useragents")
        {
            @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_UserAgentsList.cshtml", Model.UserAgents)
        }
        else if (tab == "compliance" && Model.Compliance is not null)
        {
            @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_ComplianceTab.cshtml", Model.Compliance)
        }
        else if (tab == "configuration" && Model.Configuration is not null)
        {
            ViewBag.CspNonce = Model.CspNonce;
            @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_ConfigurationEditor.cshtml", Model.Configuration)
        }
        else if (tab == "investigate" && Model.Investigation is not null)
        {
            @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_Investigate.cshtml", Model.Investigation)
        }

    </main>

    <!-- Policy modal: FOSS config snippet (globally available, triggered from endpoint rows and detail panel) -->
    <dialog id="sb-policy-modal" class="modal">
        <div class="modal-box max-w-2xl" style="background: var(--sb-card-bg); border: 1px solid var(--sb-card-border);">
            <div class="flex items-start justify-between mb-4">
                <div>
                    <h3 class="font-bold text-sm">Apply Bot Policy</h3>
                    <div class="text-xs text-base-content/50 mt-1 flex items-center gap-1.5">
                        <span class="font-mono text-[10px] px-1.5 py-0.5 rounded font-bold" style="background: var(--sb-card-subtle); color: var(--sb-brand-strong);" id="pm-method">GET</span>
                        <span class="font-mono text-xs truncate max-w-[380px]" id="pm-path">/path</span>
                    </div>
                </div>
                <form method="dialog">
                    <button class="btn btn-ghost btn-xs btn-circle"><i class="bx bx-x text-base"></i></button>
                </form>
            </div>

            <div class="flex flex-wrap gap-3 mb-4">
                <div class="flex-1 min-w-[200px]">
                    <label class="text-[10px] font-semibold text-base-content/60 uppercase tracking-wider mb-1 block">Policy</label>
                    <select id="pm-policy" class="select select-sm select-bordered w-full" onchange="sbUpdatePolicySnippet()">
                        <option value="block">block - HTTP 403 Forbidden</option>
                        <option value="throttle-stealth">throttle-stealth - Silent delay</option>
                        <option value="challenge">challenge - CAPTCHA / proof-of-work</option>
                        <option value="redirect-honeypot">redirect-honeypot - Trap redirect</option>
                        <option value="logonly">logonly - Shadow mode (no action)</option>
                    </select>
                </div>
                <div>
                    <label class="text-[10px] font-semibold text-base-content/60 uppercase tracking-wider mb-1 block">Block Threshold</label>
                    <select id="pm-threshold" class="select select-sm select-bordered" onchange="sbUpdatePolicySnippet()">
                        <option value="0.5">50% - Aggressive</option>
                        <option value="0.7" selected>70% - Standard</option>
                        <option value="0.85">85% - Conservative</option>
                        <option value="0.95">95% - High confidence only</option>
                    </select>
                </div>
            </div>

            <div class="flex gap-0 mb-3 text-xs bg-base-300 rounded-lg p-0.5 w-fit" id="pm-tabs">
                <button type="button" class="px-3 py-1 rounded-md text-xs font-medium transition-all bg-base-100 shadow-sm" onclick="sbShowSnippetTab('attribute')">C# Attribute</button>
                <button type="button" class="px-3 py-1 rounded-md text-xs font-medium transition-all text-base-content/50 hover:text-base-content/70" onclick="sbShowSnippetTab('appsettings')">appsettings.json</button>
            </div>

            <div id="pm-snippet-attribute">
                <pre id="pm-code-attribute" class="text-[11px] leading-relaxed rounded-lg p-3 overflow-x-auto" style="background: var(--sb-surface); border: 1px solid var(--sb-card-divider);"></pre>
            </div>
            <div id="pm-snippet-appsettings" style="display:none">
                <pre id="pm-code-appsettings" class="text-[11px] leading-relaxed rounded-lg p-3 overflow-x-auto" style="background: var(--sb-surface); border: 1px solid var(--sb-card-divider);"></pre>
            </div>

            <div class="flex items-center justify-between mt-3 pt-3 border-t border-base-300/40">
                <span class="text-[10px] text-base-content/40">
                    <i class="bx bx-info-circle mr-0.5"></i>FOSS: restart required after config changes
                </span>
                <button type="button" class="btn btn-sm btn-ghost gap-1.5" onclick="sbCopyPolicySnippet(this)">
                    <i class="bx bx-copy text-sm"></i>Copy
                </button>
            </div>
        </div>
        <form method="dialog" class="modal-backdrop"><button>close</button></form>
    </dialog>

    <!-- Footer with version -->
    <footer class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between text-xs" style="color: var(--sb-brand-muted);">
        <span>StyloBot &mdash; Zero-PII Bot Detection</span>
        @if (!string.IsNullOrEmpty(Model.Version))
        {
            <span>v@(Model.Version)</span>
        }
    </footer>

    <!-- SignalR → HTMX coordinator (the entire client-side JS) -->
    <script nonce="@Model.CspNonce">
    (function() {
        'use strict';

        var BASE = '@Html.Raw(bp)';
        var HUB  = '@Html.Raw(Model.HubPath)';

        // ── Widget registry ──────────────────────────────────────────────
        // Discovers all widgets on the page via data-sb-widget / data-sb-depends.
        // Each widget declares what SignalR signals it cares about.
        function getWidgetMap() {
            var map = {};  // signal → [widgetId, ...]
            document.querySelectorAll('[data-sb-widget]').forEach(function(el) {
                var deps = (el.getAttribute('data-sb-depends') || '').split(',');
                deps.forEach(function(dep) {
                    dep = dep.trim();
                    if (!dep) return;
                    if (!map[dep]) map[dep] = [];
                    var wid = el.getAttribute('data-sb-widget');
                    if (map[dep].indexOf(wid) === -1) map[dep].push(wid);
                });
            });
            return map;
        }

        // ── Debounced OOB updater ────────────────────────────────────────
        // Collects widget IDs that need updating, then fires a single
        // HTMX request to the OOB endpoint after a short debounce.
        var pending = {};
        var debounceTimer = null;
        var DEBOUNCE_MS = 500;

        function invalidate(signal) {
            var widgetMap = getWidgetMap();
            var widgets = widgetMap[signal] || [];
            widgets.forEach(function(w) { pending[w] = true; });

            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(flush, DEBOUNCE_MS);
        }

        function flush() {
            var ids = Object.keys(pending);
            if (ids.length === 0) return;
            pending = {};

            // Build the OOB update URL with current filter/sort state from the visitor list
            var url = BASE + '/partials/update?widgets=' + ids.join(',');

            // Preserve visitor list state if visitors are being updated
            if (ids.indexOf('visitors') !== -1) {
                var vl = document.getElementById('visitor-list');
                if (vl) {
                    var params = new URLSearchParams();
                    // Read current state from the last HTMX request or from filter buttons
                    var activeFilter = vl.querySelector('.bg-error\\/20, .bg-success\\/20, .shadow-sm');
                    // Just use defaults - server will return the default view
                }
            }

            // Use htmx.ajax to make the request; the server returns OOB fragments
            if (typeof htmx !== 'undefined') {
                htmx.ajax('GET', url, { target: 'body', swap: 'none' });
            }
        }

        // ── SignalR connection ────────────────────────────────────────────
        var statusEl = document.getElementById('sb-connection-status');

        function setStatus(state) {
            if (!statusEl) return;
            statusEl.className = 'w-2 h-2 rounded-full sb-' + state;
            statusEl.title = 'SignalR: ' + state;
        }

        var connection = new signalR.HubConnectionBuilder()
            .withUrl(HUB)
            .withAutomaticReconnect([0, 1000, 2000, 5000, 10000, 30000])
            .configureLogging(signalR.LogLevel.Warning)
            .build();

        // SignalR is beacon-only: server sends lightweight invalidation signals,
        // client triggers HTMX partial refreshes. No data payloads over the wire.
        connection.on('BroadcastInvalidation', function(signal) { if (signal) invalidate(signal); });

        connection.onreconnecting(function() { setStatus('connecting'); });
        connection.onreconnected(function()  { setStatus('connected'); });
        connection.onclose(function()        { setStatus('disconnected'); });

        connection.start()
            .then(function()  { setStatus('connected'); })
            .catch(function() { setStatus('disconnected'); });
    })();
    </script>

    <!-- World Threat Map + Time Series Chart initialization -->
    <script nonce="@Model.CspNonce">
    (function() {
        'use strict';
        var BASE = '@Html.Raw(bp)';

        // ── World Threat Map ─────────────────────────────────────────────
        function initMap(containerId) {
            var el = document.getElementById(containerId);
            if (!el || typeof jsVectorMap === 'undefined') return;

            var map = new jsVectorMap({
                selector: '#' + containerId,
                map: 'world_merc',
                zoomOnScroll: true,
                zoomButtons: false,
                showTooltip: true,
                backgroundColor: 'transparent',
                regionStyle: {
                    initial: { fill: '#2a2e3a', stroke: '#3a3e4a', strokeWidth: 0.5 },
                    hover: { fill: '#4a4e5a' }
                },
                series: {
                    regions: [{
                        attribute: 'fill',
                        scale: { low: '#2dd4bf', mid: '#f59e0b', high: '#ef4444' },
                        values: {},
                        min: 0, max: 1,
                        normalizeFunction: 'polynomial'
                    }]
                },
                onRegionTooltipShow: function(e, tooltip, code) {
                    var vals = map.series.regions[0].values;
                    var rate = vals[code];
                    if (rate !== undefined) {
                        var span = document.createElement('span');
                        span.textContent = ' - Bot rate: ' + (rate * 100).toFixed(0) + '%';
                        tooltip.selector.appendChild(span);
                    }
                }
            });

            function refreshMap() {
                fetch(BASE + '/api/countries')
                    .then(function(r) { return r.json(); })
                    .then(function(countries) {
                        if (!countries || countries.length === 0) return;
                        var vals = {};
                        countries.forEach(function(c) {
                            if (c.countryCode) vals[c.countryCode] = c.botRate || 0;
                        });
                        map.series.regions[0].setValues(vals);
                    })
                    .catch(function() {});
            }

            refreshMap();
            setInterval(refreshMap, 30000);
            return map;
        }

        initMap('command-map');
        initMap('countries-map');

        // ── Traffic Over Time Chart ──────────────────────────────────────
        function initTimeChart() {
            var el = document.getElementById('time-chart');
            if (!el || typeof ApexCharts === 'undefined') return;

            var chart = new ApexCharts(el, {
                chart: {
                    type: 'area', height: 160, toolbar: { show: false },
                    background: 'transparent', fontFamily: 'inherit', foreColor: '#888',
                    animations: { enabled: true, easing: 'easeinout', speed: 500 }
                },
                stroke: { curve: 'smooth', width: 2 },
                fill: { type: 'gradient', gradient: { shadeIntensity: 1, opacityFrom: 0.4, opacityTo: 0.05 } },
                colors: ['#2dd4bf', '#ef4444'],
                series: [{ name: 'Human', data: [] }, { name: 'Bot', data: [] }],
                xaxis: { type: 'datetime', labels: { style: { fontSize: '10px' }, datetimeUTC: false }, axisBorder: { show: false }, axisTicks: { show: false } },
                yaxis: { labels: { style: { fontSize: '10px' } }, min: 0 },
                grid: { borderColor: '#333', strokeDashArray: 3, padding: { left: 8, right: 8, top: 0, bottom: 0 } },
                legend: { show: true, position: 'top', fontSize: '10px', markers: { size: 4 } },
                tooltip: { theme: 'dark', x: { format: 'HH:mm' } },
                dataLabels: { enabled: false }
            });
            chart.render();

            function refreshChart() {
                fetch(BASE + '/api/timeseries')
                    .then(function(r) { return r.json(); })
                    .then(function(data) {
                        if (!data || data.length === 0) return;
                        var humans = [], bots = [];
                        data.forEach(function(pt) {
                            var ts = new Date(pt.timestamp).getTime();
                            humans.push({ x: ts, y: pt.humanCount || 0 });
                            bots.push({ x: ts, y: pt.botCount || 0 });
                        });
                        chart.updateSeries([
                            { name: 'Human', data: humans },
                            { name: 'Bot', data: bots }
                        ]);
                    })
                    .catch(function() {});
            }

            refreshChart();
            setInterval(refreshChart, 15000);
        }

        initTimeChart();
    })();
    </script>

    <!-- Policy modal JS (available globally for HTMX-loaded endpoint rows) -->
    <script nonce="@Model.CspNonce">
    (function() {
        'use strict';

        var _pmActiveTab = 'attribute';

        window.sbOpenPolicyModal = function(event, method, path, currentPolicy) {
            if (event) event.stopPropagation();
            var modal = document.getElementById('sb-policy-modal');
            if (!modal) return;

            var decodedPath = decodeURIComponent(path);
            var decodedMethod = decodeURIComponent(method);

            document.getElementById('pm-method').textContent = decodedMethod;
            document.getElementById('pm-path').textContent = decodedPath;
            modal.dataset.path = decodedPath;
            modal.dataset.method = decodedMethod;

            if (currentPolicy) {
                var sel = document.getElementById('pm-policy');
                for (var i = 0; i < sel.options.length; i++) {
                    if (sel.options[i].value === currentPolicy) { sel.selectedIndex = i; break; }
                }
            }

            sbUpdatePolicySnippet();
            modal.showModal();
        };

        window.sbUpdatePolicySnippet = function() {
            var modal = document.getElementById('sb-policy-modal');
            if (!modal) return;

            var path = modal.dataset.path || '/your/endpoint';
            var method = (modal.dataset.method || 'GET');
            var policy = document.getElementById('pm-policy').value;
            var threshold = document.getElementById('pm-threshold').value;
            var mt = method.charAt(0).toUpperCase() + method.slice(1).toLowerCase();

            var attrCode = [
                '// Controller action:',
                '[BotPolicy(ActionPolicy = "' + policy + '", BlockThreshold = ' + threshold + ')]',
                '[Http' + mt + '("' + path + '")]',
                'public IActionResult YourAction() { ... }',
                '',
                '// Minimal API:',
                'app.Map' + mt + '("' + path + '", handler)',
                '   .BotPolicy("' + policy + '", blockThreshold: ' + threshold + ');'
            ].join('\n');

            var settingsCode = [
                '{',
                '  "BotDetection": {',
                '    "DefaultActionPolicyName": "' + policy + '",',
                '    "BotThreshold": ' + threshold,
                '  }',
                '}',
                '',
                '// Sets the GLOBAL default policy (all endpoints).',
                '// Restart required. For per-endpoint control use [BotPolicy].'
            ].join('\n');

            var codeAttr = document.getElementById('pm-code-attribute');
            var codeSettings = document.getElementById('pm-code-appsettings');
            if (codeAttr) codeAttr.textContent = attrCode;
            if (codeSettings) codeSettings.textContent = settingsCode;
        };

        window.sbShowSnippetTab = function(tabName) {
            _pmActiveTab = tabName;
            var tabs = document.querySelectorAll('#pm-tabs button');
            tabs.forEach(function(t, i) {
                var isActive = (i === 0 && tabName === 'attribute') || (i === 1 && tabName === 'appsettings');
                t.className = isActive
                    ? 'px-3 py-1 rounded-md text-xs font-medium transition-all bg-base-100 shadow-sm'
                    : 'px-3 py-1 rounded-md text-xs font-medium transition-all text-base-content/50 hover:text-base-content/70';
            });
            var attrDiv = document.getElementById('pm-snippet-attribute');
            var appDiv  = document.getElementById('pm-snippet-appsettings');
            if (attrDiv) attrDiv.style.display = tabName === 'attribute' ? '' : 'none';
            if (appDiv)  appDiv.style.display  = tabName === 'appsettings' ? '' : 'none';
        };

        window.sbCopyPolicySnippet = function(btn) {
            var elId = _pmActiveTab === 'attribute' ? 'pm-code-attribute' : 'pm-code-appsettings';
            var codeEl = document.getElementById(elId);
            if (!codeEl) return;
            var text = codeEl.textContent;

            function flashBtn(ok) {
                if (!btn) return;
                var icon = btn.querySelector('i');
                if (icon) icon.className = ok ? 'bx bx-check text-sm text-success' : 'bx bx-copy text-sm';
                setTimeout(function() { if (icon) icon.className = 'bx bx-copy text-sm'; }, 1500);
            }

            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(text).then(function() { flashBtn(true); }).catch(function() { sbFbCopy(codeEl); flashBtn(true); });
            } else {
                sbFbCopy(codeEl); flashBtn(true);
            }
        };

        function sbFbCopy(el) {
            var r = document.createRange();
            r.selectNode(el);
            window.getSelection().removeAllRanges();
            window.getSelection().addRange(r);
            try { document.execCommand('copy'); } catch(e) {}
            window.getSelection().removeAllRanges();
        }
    })();
    </script>
</body>
</html>