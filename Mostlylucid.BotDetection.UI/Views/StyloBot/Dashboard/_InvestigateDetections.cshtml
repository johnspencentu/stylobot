@model Mostlylucid.BotDetection.UI.Models.InvestigationViewModel
@{
    var bp = Model.BasePath;
    var f = Model.Filter;
}

<div class="sb-investigate-detections">
    <table style="width:100%; border-collapse:collapse; font-size:0.85rem;">
        <thead>
            <tr style="border-bottom:2px solid var(--sb-card-border); text-align:left;">
                <th style="padding:0.5rem;">Time</th>
                <th style="padding:0.5rem;">Path</th>
                <th style="padding:0.5rem;">Risk</th>
                <th style="padding:0.5rem;">Action</th>
                <th style="padding:0.5rem;">Bot</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in Model.Result.Detections)
            {
                var riskColor = d.RiskBand switch { "high" => "var(--sb-signal-danger)", "medium" => "var(--sb-signal-warn)", _ => "var(--sb-signal-pos)" };
                <tr style="border-bottom:1px solid var(--sb-card-divider); cursor:pointer;"
                    onclick="this.nextElementSibling.style.display = this.nextElementSibling.style.display === 'none' ? 'table-row' : 'none'">
                    <td style="padding:0.5rem; white-space:nowrap;">@d.Timestamp.ToString("MMM dd HH:mm:ss")</td>
                    <td style="padding:0.5rem; font-family:monospace; font-size:0.8rem;">@d.Method @d.Path</td>
                    <td style="padding:0.5rem;"><span style="color:@riskColor; font-weight:600;">@d.RiskBand</span></td>
                    <td style="padding:0.5rem;">@d.Action</td>
                    <td style="padding:0.5rem;">@(d.BotName ?? d.BotType ?? "--")</td>
                </tr>
                <tr style="display:none; background:var(--sb-surface);">
                    <td colspan="5" style="padding:0.75rem;">
                        @if (d.DetectorContributions?.Any() == true)
                        {
                            <div style="margin-bottom:0.5rem;">
                                <strong style="font-size:0.75rem;">Detector Contributions</strong>
                                <div style="display:flex; gap:0.5rem; flex-wrap:wrap; margin-top:0.25rem;">
                                    @foreach (var (name, contrib) in d.DetectorContributions)
                                    {
                                        <span style="padding:0.15rem 0.5rem; background:var(--sb-card-bg); border-radius:4px; font-size:0.75rem;">
                                            @name: @contrib.Contribution.ToString("P0")
                                            @if (!string.IsNullOrEmpty(contrib.Reason)) { <em>(@contrib.Reason)</em> }
                                        </span>
                                    }
                                </div>
                            </div>
                        }
                        @if (d.ImportantSignals?.Any() == true)
                        {
                            <div>
                                <strong style="font-size:0.75rem;">Signals</strong>
                                <div style="display:flex; gap:0.5rem; flex-wrap:wrap; margin-top:0.25rem;">
                                    @foreach (var (key, val) in d.ImportantSignals)
                                    {
                                        <span style="padding:0.15rem 0.5rem; background:var(--sb-card-bg); border-radius:4px; font-size:0.75rem; font-family:monospace;">@key=@val</span>
                                    }
                                </div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(d.Description))
                        {
                            <p style="margin-top:0.5rem; font-size:0.8rem; color:var(--sb-brand-muted);">@d.Description</p>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <div style="display:flex; justify-content:center; gap:0.5rem; padding:1rem;">
            @for (var p = 1; p <= Math.Min(Model.TotalPages, 10); p++)
            {
                <button hx-get="@bp/investigate/tab/detections?type=@f.EntityType&value=@f.EntityValue&start=@f.Start?.ToString("o")&end=@f.End?.ToString("o")&offset=@((p-1) * f.Limit)"
                        hx-target="#investigate-tab-content"
                        hx-swap="innerHTML transition:true"
                        style="padding:0.3rem 0.6rem; border-radius:4px; border:1px solid var(--sb-card-border); background:@(p == Model.CurrentPage ? "var(--sb-accent)" : "var(--sb-surface)"); color:@(p == Model.CurrentPage ? "white" : "inherit"); cursor:pointer; font-size:0.8rem;">
                    @p
                </button>
            }
        </div>
    }
</div>
