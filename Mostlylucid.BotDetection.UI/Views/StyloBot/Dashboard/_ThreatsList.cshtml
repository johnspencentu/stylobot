@using Mostlylucid.BotDetection.UI.Models
@model ThreatsListModel

<div id="threats-widget" data-sb-widget="threats" data-sb-depends="threats">
    <div class="card bg-base-200 transition-all duration-200">
        <div class="card-body p-3">
            <div class="flex items-center justify-between mb-2">
                <h3 class="text-sm font-bold text-base-content">Threat Intelligence</h3>
                <div class="flex items-center gap-2">
                    <span class="badge badge-error badge-sm">@Model.Threats.Count(t => t.CveSeverity == "critical") Critical</span>
                    <span class="badge badge-warning badge-sm">@Model.Threats.Count(t => t.CveSeverity == "high") High</span>
                    <span class="badge badge-info badge-sm">@Model.Threats.Count(t => t.InHoneypot) In Honeypot</span>
                </div>
            </div>

            @if (!Model.Threats.Any())
            {
                <div class="text-center py-8 text-base-content/50">
                    <p class="text-sm">No threat activity detected yet.</p>
                    <p class="text-xs mt-1">CVE probes and honeypot engagements will appear here.</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="table table-xs table-zebra w-full">
                        <thead>
                            <tr class="text-[10px] uppercase tracking-wider">
                                <th class="py-1">Time</th>
                                <th class="py-1">CVE</th>
                                <th class="py-1">Severity</th>
                                <th class="py-1">Path</th>
                                <th class="py-1">Bot</th>
                                <th class="py-1">Threat</th>
                                <th class="py-1">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var threat in Model.Threats)
                            {
                                <tr class="@(threat.InHoneypot ? "bg-error/5" : "")">
                                    <td class="text-xs whitespace-nowrap">@threat.Timestamp.ToString("HH:mm:ss")</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(threat.CveId))
                                        {
                                            <a href="https://nvd.nist.gov/vuln/detail/@threat.CveId" target="_blank" rel="noopener"
                                               class="link link-primary text-xs font-mono">@threat.CveId</a>
                                        }
                                        else
                                        {
                                            <span class="text-xs text-base-content/40">-</span>
                                        }
                                    </td>
                                    <td>
                                        @{
                                            var severityClass = threat.CveSeverity switch
                                            {
                                                "critical" => "badge-error",
                                                "high" => "badge-warning",
                                                "medium" => "badge-info",
                                                _ => "badge-ghost"
                                            };
                                        }
                                        <span class="badge @severityClass badge-xs">@(threat.CveSeverity ?? "probe")</span>
                                    </td>
                                    <td class="text-xs font-mono max-w-[200px] truncate" title="@threat.Path">@threat.Path</td>
                                    <td class="text-xs">@(threat.BotName ?? "Unknown")</td>
                                    <td>
                                        @{
                                            var threatClass = threat.ThreatScore switch
                                            {
                                                >= 0.8 => "text-error",
                                                >= 0.55 => "text-warning",
                                                >= 0.35 => "text-info",
                                                _ => "text-base-content/50"
                                            };
                                        }
                                        <span class="text-xs font-semibold @threatClass">@threat.ThreatScore.ToString("F2")</span>
                                    </td>
                                    <td>
                                        @if (threat.InHoneypot)
                                        {
                                            <span class="badge badge-error badge-xs gap-1">
                                                <span class="w-1.5 h-1.5 rounded-full bg-error animate-pulse"></span>
                                                Honeypot
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-ghost badge-xs">Detected</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
