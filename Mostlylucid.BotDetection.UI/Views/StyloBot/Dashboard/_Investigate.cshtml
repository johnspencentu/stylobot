@model Mostlylucid.BotDetection.UI.Models.InvestigationViewModel
@{
    var f = Model.Filter;
    var s = Model.Result.Summary;
    var bp = Model.BasePath;
}

<div id="investigate-view" data-sb-widget="investigate" class="sb-investigate">

    <div class="sb-investigate-filter"
         style="display:flex; gap:0.5rem; align-items:center; padding:0.75rem 1rem; background:var(--sb-card-bg); border:1px solid var(--sb-card-border); border-radius:8px; margin-bottom:1rem;">

        <select id="inv-entity-type" name="type" style="padding:0.4rem 0.6rem; border-radius:6px; border:1px solid var(--sb-card-border); background:var(--sb-surface); color:inherit; font-size:0.85rem;">
            @foreach (var opt in Model.AvailableFilters)
            {
                <option value="@opt.Value" @(opt.Value == f.EntityType ? "selected" : "")>@opt.Label</option>
            }
        </select>

        <input id="inv-entity-value" name="value" type="text" value="@f.EntityValue"
               placeholder="Enter value..."
               style="flex:1; padding:0.4rem 0.6rem; border-radius:6px; border:1px solid var(--sb-card-border); background:var(--sb-surface); color:inherit; font-size:0.85rem;" />

        <div style="display:flex; gap:2px;">
            @foreach (var val in new[] { "1h", "6h", "24h", "7d", "30d" })
            {
                <button class="sb-pill"
                        hx-get="@bp/investigate?type=@f.EntityType&value=@f.EntityValue&range=@val"
                        hx-target="#investigate-view"
                        hx-swap="outerHTML transition:true"
                        style="padding:0.3rem 0.6rem; border-radius:4px; border:1px solid var(--sb-card-border); background:var(--sb-surface); color:inherit; font-size:0.75rem; cursor:pointer;">
                    @val
                </button>
            }
        </div>

        <button hx-get="@bp/investigate"
                hx-include="#inv-entity-type, #inv-entity-value"
                hx-target="#investigate-view"
                hx-swap="outerHTML transition:true"
                style="padding:0.4rem 0.8rem; border-radius:6px; background:var(--sb-accent); color:white; border:none; cursor:pointer; font-size:0.85rem;">
            Apply
        </button>
    </div>

    @if (s.TotalDetections > 0)
    {
        <div style="display:flex; gap:1rem; flex-wrap:wrap; align-items:center; padding:0.75rem 1rem; background:var(--sb-card-bg); border:1px solid var(--sb-card-border); border-radius:8px; margin-bottom:1rem; font-size:0.85rem;">
            <span style="font-weight:600;">@s.TotalDetections detections</span>
            @if (s.FirstSeen.HasValue)
            {
                <span style="color:var(--sb-brand-muted);">First: @s.FirstSeen.Value.ToString("MMM dd HH:mm")</span>
                <span style="color:var(--sb-brand-muted);">Last: @s.LastSeen?.ToString("MMM dd HH:mm")</span>
            }
            <span>
                <span style="color:var(--sb-signal-danger); font-weight:500;">@s.HighRisk high</span> |
                <span style="color:var(--sb-signal-warn); font-weight:500;">@s.MediumRisk med</span> |
                <span style="color:var(--sb-signal-pos); font-weight:500;">@s.LowRisk low</span>
            </span>
            @foreach (var reason in s.TopReasons.Take(3))
            {
                <span style="padding:0.15rem 0.5rem; background:var(--sb-surface); border-radius:4px; font-size:0.75rem;">@reason</span>
            }
        </div>

        <div style="display:flex; gap:2px; border-bottom:1px solid var(--sb-card-border); margin-bottom:1rem;">
            @foreach (var tab in Model.AvailableTabs)
            {
                var isActive = tab == Model.ActiveTab;
                var displayName = tab switch { "signaltrace" => "Signal Trace", "ua_family" => "UA Family", _ => char.ToUpper(tab[0]) + tab[1..] };
                <button hx-get="@bp/investigate/tab/@tab?type=@f.EntityType&value=@f.EntityValue&start=@f.Start?.ToString("o")&end=@f.End?.ToString("o")"
                        hx-target="#investigate-tab-content"
                        hx-swap="innerHTML transition:true"
                        style="padding:0.5rem 1rem; border:none; background:@(isActive ? "var(--sb-card-bg)" : "transparent"); color:@(isActive ? "var(--sb-accent)" : "inherit"); border-bottom:2px solid @(isActive ? "var(--sb-accent)" : "transparent"); cursor:pointer; font-size:0.85rem; font-weight:@(isActive ? "600" : "400");">
                    @displayName
                </button>
            }
        </div>

        <div id="investigate-tab-content">
            @switch (Model.ActiveTab)
            {
                case "detections":
                    @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_InvestigateDetections.cshtml", Model)
                    break;
                case "signatures":
                    @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_InvestigateSignatures.cshtml", Model)
                    break;
                case "endpoints":
                    @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_InvestigateEndpoints.cshtml", Model)
                    break;
                case "geo":
                    @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_InvestigateGeo.cshtml", Model)
                    break;
                case "fingerprints":
                    @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_InvestigateFingerprints.cshtml", Model)
                    break;
                case "signaltrace":
                    @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_InvestigateSignaltrace.cshtml", Model)
                    break;
                default:
                    @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_InvestigateDetections.cshtml", Model)
                    break;
            }
        </div>
    }
    else if (!string.IsNullOrEmpty(f.EntityValue))
    {
        <div style="padding:2rem; text-align:center; color:var(--sb-brand-muted);">
            No detections found for this filter. Try a different entity or time range.
        </div>
    }
</div>
