@model Mostlylucid.BotDetection.UI.Models.ShapeInvestigationViewModel
@{
    var s = Model.Result.Summary;
    var bp = Model.BasePath;

    // Build compatibility ViewModel for tab partials that still expect InvestigationViewModel
    var tabVm = new Mostlylucid.BotDetection.UI.Models.InvestigationViewModel
    {
        Filter = new Mostlylucid.BotDetection.UI.Models.InvestigationFilter
        {
            EntityType = "shape",
            EntityValue = "",
            Start = Model.Filter.Start,
            End = Model.Filter.End,
            Tab = Model.ActiveTab,
            Offset = Model.Filter.Offset,
            Limit = Model.Filter.Limit
        },
        Result = Model.Result,
        BasePath = Model.BasePath,
        AvailableTabs = Model.AvailableTabs
    };
}

<div id="investigate-view" data-sb-widget="investigate" class="sb-investigate">

    @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_ShapeFilterBar.cshtml", Model)

    @if (s.TotalDetections > 0)
    {
        <div style="display:flex; gap:1rem; flex-wrap:wrap; align-items:center; padding:0.75rem 1rem; background:var(--sb-card-bg); border:1px solid var(--sb-card-border); border-radius:8px; margin-bottom:1rem; font-size:0.85rem;">
            <span style="font-weight:600;">@s.TotalDetections detections</span>
            @if (s.FirstSeen.HasValue)
            {
                <span style="color:var(--sb-brand-muted);">First: @s.FirstSeen.Value.ToString("MMM dd HH:mm")</span>
                <span style="color:var(--sb-brand-muted);">Last: @s.LastSeen?.ToString("MMM dd HH:mm")</span>
            }
            <span>
                <span style="color:var(--sb-signal-danger); font-weight:500;">@s.HighRisk high</span> |
                <span style="color:var(--sb-signal-warn); font-weight:500;">@s.MediumRisk med</span> |
                <span style="color:var(--sb-signal-pos); font-weight:500;">@s.LowRisk low</span>
            </span>
            @foreach (var reason in s.TopReasons.Take(3))
            {
                <span style="padding:0.15rem 0.5rem; background:var(--sb-surface); border-radius:4px; font-size:0.75rem;">@reason</span>
            }
        </div>

        @* ── Ghost campaign matches (commercial PostgreSQL only) ──────────────── *@
        @if (Model.Result.GhostMatches.Count > 0)
        {
            <div style="padding:0.75rem 1rem; background:rgba(var(--sb-accent-rgb, 99,102,241),0.06); border:1px solid var(--sb-accent); border-radius:8px; margin-bottom:1rem;">
                <div style="display:flex; align-items:center; gap:0.5rem; margin-bottom:0.5rem;">
                    <span style="font-size:0.8rem; font-weight:700; color:var(--sb-accent); text-transform:uppercase; letter-spacing:0.05em;">Dormant Campaign Match</span>
                    <span style="font-size:0.75rem; color:var(--sb-brand-muted);">Signatures in this result match crystallized past campaigns</span>
                </div>
                @foreach (var ghost in Model.Result.GhostMatches.Take(5))
                {
                    var simPct = (ghost.Similarity * 100).ToString("F0");
                    var riskColor = ghost.RiskBand switch {
                        "Critical" => "var(--sb-signal-danger)",
                        "High"     => "var(--sb-signal-danger)",
                        "Medium"   => "var(--sb-signal-warn)",
                        _          => "var(--sb-signal-pos)"
                    };
                    <div style="display:flex; gap:1rem; align-items:center; padding:0.4rem 0; border-top:1px solid var(--sb-card-divider); font-size:0.82rem;">
                        <span style="font-weight:600; color:@riskColor; min-width:3rem;">@simPct%</span>
                        <span style="font-family:monospace; font-size:0.75rem; color:var(--sb-brand-muted);">@ghost.FamilyId</span>
                        @if (!string.IsNullOrEmpty(ghost.Label))
                        {
                            <span style="font-weight:500;">@ghost.Label</span>
                        }
                        <span style="color:var(--sb-brand-muted);">@ghost.SignatureCount sig@(ghost.SignatureCount == 1 ? "" : "s")</span>
                        <span style="color:var(--sb-brand-muted);">via @(ghost.MatchedSignature.Length > 8 ? ghost.MatchedSignature[..8] + "…" : ghost.MatchedSignature)</span>
                        <span style="color:var(--sb-brand-muted); margin-left:auto;">last @ghost.LastSeen.ToString("MMM dd yyyy")</span>
                    </div>
                }
            </div>
        }

        <div style="display:flex; gap:2px; border-bottom:1px solid var(--sb-card-border); margin-bottom:1rem;">
            @foreach (var tab in Model.AvailableTabs)
            {
                var isActive = tab == Model.ActiveTab;
                var displayName = tab switch { "signaltrace" => "Signal Trace", "ua_family" => "UA Family", _ => char.ToUpper(tab[0]) + tab[1..] };
                <button hx-get="@bp/investigate/tab/@tab?start=@Model.Filter.Start?.ToString("o")&end=@Model.Filter.End?.ToString("o")"
                        hx-target="#investigate-tab-content"
                        hx-swap="innerHTML transition:true"
                        style="padding:0.5rem 1rem; border:none; background:@(isActive ? "var(--sb-card-bg)" : "transparent"); color:@(isActive ? "var(--sb-accent)" : "inherit"); border-bottom:2px solid @(isActive ? "var(--sb-accent)" : "transparent"); cursor:pointer; font-size:0.85rem; font-weight:@(isActive ? "600" : "400");">
                    @displayName
                </button>
            }
        </div>

        <div id="investigate-tab-content">
            @switch (Model.ActiveTab)
            {
                case "detections":
                    @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_InvestigateDetections.cshtml", tabVm)
                    break;
                case "signatures":
                    @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_InvestigateSignatures.cshtml", tabVm)
                    break;
                case "endpoints":
                    @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_InvestigateEndpoints.cshtml", tabVm)
                    break;
                case "geo":
                    @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_InvestigateGeo.cshtml", tabVm)
                    break;
                case "fingerprints":
                    @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_InvestigateFingerprints.cshtml", tabVm)
                    break;
                case "signaltrace":
                    @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_InvestigateSignaltrace.cshtml", tabVm)
                    break;
                default:
                    @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_InvestigateDetections.cshtml", tabVm)
                    break;
            }
        </div>
    }
    else
    {
        <div style="padding:2rem; text-align:center; color:var(--sb-brand-muted);">
            No detections found. Adjust the shape filters or time range above.
        </div>
        @if (Model.Result.VoidPressure > 0.05f)
        {
            var pressure = Model.Result.VoidPressure;
            var pct = (pressure * 100).ToString("F0");
            var pressureColor = pressure > 0.7f ? "var(--sb-signal-danger)"
                              : pressure > 0.4f ? "var(--sb-signal-warn)"
                              : "var(--sb-brand-muted)";
            <div style="margin-top:1rem; padding:0.75rem 1.25rem; background:var(--sb-surface); border:1px solid var(--sb-card-divider); border-radius:8px; display:inline-block; text-align:left; min-width:300px;">
                <div style="font-size:0.8rem; font-weight:600; color:@pressureColor; margin-bottom:0.25rem;">
                    Unknown-Space Pressure: @pct%
                </div>
                <div style="background:var(--sb-card-bg); border-radius:4px; height:6px; overflow:hidden; margin-bottom:0.5rem;">
                    <div style="width:@(pct)%; height:100%; background:@pressureColor; border-radius:4px; transition:width 0.3s;"></div>
                </div>
                <p style="font-size:0.75rem; margin:0; color:var(--sb-brand-muted); line-height:1.5;">
                    This shape sits <strong style="color:@pressureColor;">@pct% away</strong> from the nearest known detection in behavioural space.
                    High pressure is not inherently bad -- rare but legitimate visitors can also have unique shapes.
                    Consider it a contributor signal alongside bot probability and risk band.
                </p>
            </div>
        }
    }
</div>
