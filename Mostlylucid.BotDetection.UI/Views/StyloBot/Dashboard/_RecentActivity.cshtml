@using Mostlylucid.BotDetection.UI.Models
@using Mostlylucid.BotDetection.UI.Helpers
@model VisitorListModel
@{
    var bp = Model.BasePath;
    var navBp = Model.ResolvedNavBasePath;
    string SortUrl(string field) {
        var dir = Model.SortField == field ? (Model.SortDir == "desc" ? "asc" : "desc") : "desc";
        return $"{bp}/partials/recent?sort={field}&dir={dir}&page=1&pageSize={Model.PageSize}";
    }
    string PageUrl(int page) => $"{bp}/partials/recent?filter={Model.Filter ?? "all"}&sort={Model.SortField}&dir={Model.SortDir}&page={page}&pageSize={Model.PageSize}";
    string SortIcon(string field) => Model.SortField == field ? (Model.SortDir == "asc" ? " \u25B2" : " \u25BC") : "";
    string ThClass(string field) => Model.SortField == field
        ? "text-base-content/70 font-bold"
        : "text-base-content/40 hover:text-base-content/60";

    bool HasFlag(string? code) => !string.IsNullOrEmpty(code) && code.Length == 2 && code != "XX";
    string FlagUrl(string code) => $"https://flagcdn.com/w40/{code.ToLowerInvariant()}.png";
}
@{
    var filter = Model.Filter ?? "all";
    string FilterUrl(string f) => $"{bp}/partials/recent?filter={f}&sort={Model.SortField}&dir={Model.SortDir}&page=1&pageSize={Model.PageSize}";
    string FilterClass(string f) => filter == f ? "btn-active font-bold" : "btn-ghost text-base-content/50";
}
<div id="recent-activity"
     data-sb-widget="recent"
     data-sb-depends="signature,summary"
     hx-get="@bp/partials/recent?filter=@filter&sort=@Model.SortField&dir=@Model.SortDir&page=@Model.Page&pageSize=@Model.PageSize"
     hx-trigger="every 10s"
     hx-swap="outerHTML"
     class="card bg-base-200 transition-all duration-200">
    <div class="card-body p-3">
        <div class="flex items-center justify-between mb-1">
            <div class="flex items-center gap-2">
                <h3 class="text-sm font-bold text-base-content">Recent Activity</h3>
                @await Html.PartialAsync("~/Views/StyloBot/Dashboard/_HelpIcon.cshtml", "recent-activity")
                <span class="text-[9px] px-1 py-0.5 rounded status-badge-danger font-medium">LIVE</span>
            </div>
            <div class="flex items-center gap-1">
                <div class="join join-horizontal">
                    <button class="join-item btn btn-xs @FilterClass("all")"
                            hx-get="@FilterUrl("all")" hx-target="#recent-activity" hx-swap="outerHTML">All</button>
                    <button class="join-item btn btn-xs @FilterClass("bots")"
                            hx-get="@FilterUrl("bots")" hx-target="#recent-activity" hx-swap="outerHTML">Bots</button>
                    <button class="join-item btn btn-xs @FilterClass("humans")"
                            hx-get="@FilterUrl("humans")" hx-target="#recent-activity" hx-swap="outerHTML">Humans</button>
                    <button class="join-item btn btn-xs @FilterClass("threats")"
                            hx-get="@FilterUrl("threats")" hx-target="#recent-activity" hx-swap="outerHTML">Threats</button>
                </div>
            </div>
        </div>

        @if (Model.Visitors.Count == 0)
        {
            <div class="text-xs text-base-content/40 py-4 text-center">No activity yet</div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="table table-xs w-full">
                    <thead>
                        <tr class="text-[10px] uppercase tracking-wider">
                            <th class="py-0.5 @ThClass("lastSeen") cursor-pointer"
                                hx-get="@SortUrl("lastSeen")" hx-target="#recent-activity" hx-swap="outerHTML transition:true">
                                Time@(Html.Raw(SortIcon("lastSeen")))
                            </th>
                            <th class="py-0.5 @ThClass("name") cursor-pointer"
                                hx-get="@SortUrl("name")" hx-target="#recent-activity" hx-swap="outerHTML transition:true">
                                Name@(Html.Raw(SortIcon("name")))
                            </th>
                            <th class="py-0.5">Intent</th>
                            <th class="py-0.5">Threat</th>
                            <th class="py-0.5 text-right @ThClass("risk") cursor-pointer"
                                hx-get="@SortUrl("risk")" hx-target="#recent-activity" hx-swap="outerHTML transition:true">
                                Prob@(Html.Raw(SortIcon("risk")))
                            </th>
                            <th class="py-0.5">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in Model.Visitors)
                        {
                            var displayName = v.BotName ?? (string.IsNullOrEmpty(v.BotType)
                                ? (v.IsBot ? DeterministicBotName(v.PrimarySignature) : "Visitor")
                                : v.BotType);
                            var isLlmNamed = v.BotName != null;
                            var displayIntent = v.BotType ?? (v.IsBot ? DeterministicIntent(v.BotProbability) : "Human");
                            var displayThreat = ResolvedThreat(v.ThreatBand, v.BotProbability, v.IsBot);
                            var probPct = (v.BotProbability * 100).ToString("F0");
                            var riskClass = v.RiskBand switch {
                                "VeryHigh" or "High" => "text-error",
                                "Medium" or "Elevated" => "text-warning",
                                _ => "text-success"
                            };
                            var threatClass = displayThreat switch {
                                "Critical" => "text-error font-bold",
                                "High" => "text-error",
                                "Medium" => "text-warning",
                                _ => "text-base-content/30"
                            };
                            var actionClass = ActionDisplayHelper.GetCssClass(v.Action);
                            var friendlyAction = ActionDisplayHelper.GetFriendlyName(v.Action);
                            <tr class="hover:bg-base-300/50 cursor-pointer transition-colors">
                                <td class="py-0.5 text-base-content/50 whitespace-nowrap text-[10px]">
                                    <a href="@bp/signature/@Uri.EscapeDataString(v.PrimarySignature)">@v.TimeAgo</a>
                                </td>
                                <td class="py-0.5 font-medium text-xs truncate max-w-[120px]" title="@(v.BotName ?? v.PrimarySignature)">
                                    <a href="@bp/signature/@Uri.EscapeDataString(v.PrimarySignature)" class="inline-flex items-center gap-1 hover:underline @(isLlmNamed ? "" : (v.IsBot ? "text-base-content/60 italic" : ""))">
                                        @if (HasFlag(v.CountryCode))
                                        {
                                            <img src="@FlagUrl(v.CountryCode!)" alt="@v.CountryCode" class="w-5 h-3.5 object-cover rounded-sm inline" loading="lazy" />
                                        }
                                        <span>@displayName</span>
                                    </a>
                                </td>
                                <td class="py-0.5 text-[10px] text-base-content/50">@displayIntent</td>
                                <td class="py-0.5 text-[10px] @threatClass">@displayThreat</td>
                                <td class="py-0.5 text-right font-bold text-xs @riskClass">@(probPct)%</td>
                                <td class="py-0.5 text-[10px] @actionClass font-medium">@friendlyAction</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <div class="flex items-center justify-between mt-1.5 pt-1.5 border-t border-base-300">
                    <span class="text-[10px] text-base-content/40">@Model.TotalCount total &middot; page @Model.Page/@Model.TotalPages</span>
                    <div class="flex items-center gap-1">
                        @if (Model.Page > 1)
                        {
                            <button hx-get="@PageUrl(Model.Page - 1)" hx-target="#recent-activity" hx-swap="outerHTML transition:true"
                                    class="btn btn-xs btn-ghost">&lsaquo; Prev</button>
                        }
                        @if (Model.Page < Model.TotalPages)
                        {
                            <button hx-get="@PageUrl(Model.Page + 1)" hx-target="#recent-activity" hx-swap="outerHTML transition:true"
                                    class="btn btn-xs btn-ghost">Next &rsaquo;</button>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>

@functions {
    static readonly string[] Adj = [
        "Rapid", "Silent", "Dark", "Stealth", "Ghost", "Shadow", "Covert",
        "Phantom", "Masked", "Rogue", "Blind", "Hollow", "Lurking", "Drifting",
        "Probing", "Scanning", "Null", "Void", "Bare", "Headless"
    ];
    static readonly string[] Noun = [
        "Crawler", "Scanner", "Probe", "Agent", "Harvester", "Indexer",
        "Spider", "Tracer", "Snatcher", "Digger", "Drifter", "Hunter",
        "Seeker", "Scraper", "Collector", "Watcher", "Trawler", "Requester"
    ];

    string DeterministicBotName(string sig) {
        if (string.IsNullOrEmpty(sig)) return "Bot";
        var h = Math.Abs(sig.GetHashCode());
        return $"{Adj[h % Adj.Length]} {Noun[(h / Adj.Length) % Noun.Length]}";
    }

    string DeterministicIntent(double prob) => prob switch {
        >= 0.95 => "Automated",
        >= 0.80 => "Scanner",
        >= 0.60 => "Crawler",
        _ => "Probe"
    };

    string ResolvedThreat(string? band, double prob, bool isBot) {
        if (!string.IsNullOrEmpty(band) && band != "None") return band;
        if (!isBot) return "";
        return prob switch {
            >= 0.95 => "High",
            >= 0.75 => "Medium",
            _ => "Low"
        };
    }
}
